<!-- Header -->
<div class="admin-header">
    <h4 class="mb-0" style="color: var(--primary-gold);">
        <i class="bi bi-diagram-3 me-2"></i>ตารางแข่งขัน
    </h4>
    <div class="d-flex gap-2">
        <button class="btn btn-admin-outline btn-sm" onclick="resetBracket()">
            <i class="bi bi-arrow-counterclockwise me-1"></i>รีเซ็ตการจับคู่
        </button>
        <button class="btn btn-admin btn-sm" onclick="generateBracket()">
            <i class="bi bi-magic me-1"></i>สร้างตารางอัตโนมัติ
        </button>
    </div>
</div>

<!-- Bracket Container -->
<div class="admin-card bracket-admin-card">
    <div id="bracketContainer" class="bracket-state">
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
        </div>
    </div>
</div>

<!-- Edit Match Modal -->
<div class="modal fade" id="matchModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark" style="border: 1px solid var(--border-color);">
            <div class="modal-header" style="border-color: var(--border-color);">
                <h5 class="modal-title" style="color: var(--primary-gold);">จัดการคู่แข่งขัน</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="matchId">
                <input type="hidden" id="matchRound">
                <div class="mb-3">
                    <label class="form-label">รอบการแข่งขัน</label>
                    <input type="text" class="form-control bg-dark text-light" id="matchRoundLabel" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">ทีมที่ 1</label>
                    <select class="form-select bg-light text-light" id="team1Id">
                        <option value="">-- ว่าง --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">ทีมที่ 2</label>
                    <select class="form-select bg-dark text-light" id="team2Id">
                        <option value="">-- ว่าง --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">ทีมที่ชนะ</label>
                    <select class="form-select bg-dark text-light" id="winnerId">
                        <option value="">-- ยังไม่มี --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">สถานะ</label>
                    <select class="form-select bg-dark text-light" id="matchStatus">
                        <option value="pending">รอแข่ง</option>
                        <option value="ongoing">กำลังแข่ง</option>
                        <option value="completed">จบแล้ว</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">เวลาแข่งขัน</label>
                    <input type="datetime-local" class="form-control bg-dark text-light" id="matchTime">
                </div>
                <div class="mb-3">
                    <label class="form-label">ลิงก์ถ่ายทอดสด</label>
                    <input type="url" class="form-control bg-dark text-light" id="matchStream">
                </div>
                <div class="mb-3">
                    <label class="form-label">หมายเหตุ</label>
                    <textarea class="form-control bg-dark text-light" id="matchNotes" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer" style="border-color: var(--border-color);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-danger" onclick="deleteMatch()">ลบคู่นี้</button>
                <button type="button" class="btn btn-admin" onclick="saveMatch()">บันทึก</button>
            </div>
        </div>
    </div>
</div>

<script>
    const preferredRounds = ['round_1', 'round_2', 'quarter', 'semi', 'final'];
    const roundTextMap = {
        round_1: 'รอบแรก',
        round_2: 'รอบถัดไป',
        quarter: 'รอบ 8 ทีม',
        semi: 'รอบรองชนะเลิศ',
        final: 'รอบชิงชนะเลิศ'
    };
    const boardConfig = {
        headerHeight: 94,
        cardWidth: 340,
        cardHeight: 388,
        columnGap: 140,
        rowGap: 36,
        paddingLeft: 8,
        paddingRight: 24,
        paddingBottom: 24
    };

    let teamsList = [];
    let bracketData = [];
    let initialRoundMatchCount = 0;

    enableGrabScroll(document.querySelector('.bracket-admin-card'));

    fetch('/api/admin/teams?status=approved', { credentials: 'include', method: 'GET' })
        .then(res => res.json())
        .then(result => {
            if (result.success) {
                teamsList = result.data || [];
                populateTeamSelects();
                if (bracketData.length || initialRoundMatchCount) {
                    renderCurrentBracket();
                }
            }
        }, () => {
            teamsList = [];
        });

    loadBracket();

    function loadBracket() {
        renderLoadingState();

        fetch('/api/admin/bracket', { credentials: 'include', method: 'GET' })
            .then(res => res.json())
            .then(result => {
                if (!result.success) {
                    renderState('error');
                    return;
                }

                bracketData = result.data || [];
                initialRoundMatchCount = result.meta?.initial_round_1_match_count || 0;
                sortBracketMatches(bracketData);
                renderCurrentBracket();
            }, () => {
                renderState('error');
            });
    }

    function renderLoadingState() {
        document.getElementById('bracketContainer').innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-warning" role="status"></div>
            </div>
        `;
    }

    function renderState(type) {
        const container = document.getElementById('bracketContainer');

        if (type === 'empty') {
            container.innerHTML = `
                <div class="state-card">
                    <i class="bi bi-calendar-x state-icon"></i>
                    <h4>ยังไม่มีตารางการแข่งขัน</h4>
                    <p>กด "สร้างตารางอัตโนมัติ" เพื่อเริ่มจัดสายการแข่ง</p>
                </div>
            `;
            return;
        }

        container.innerHTML = `
            <div class="state-card">
                <i class="bi bi-exclamation-circle state-icon is-error"></i>
                <h4>โหลดข้อมูลไม่สำเร็จ</h4>
                <p>ลองรีเฟรชอีกครั้งหรือเช็กการเชื่อมต่อระบบหลังบ้าน</p>
            </div>
        `;
    }

    function buildRoundStructure(matches, fallbackFirstRoundMatchCount) {
        const grouped = {};

        matches.forEach(match => {
            if (!grouped[match.round]) {
                grouped[match.round] = [];
            }

            grouped[match.round].push(match);
        });

        Object.keys(grouped).forEach(roundKey => {
            grouped[roundKey].sort((left, right) => (left.match_number || 0) - (right.match_number || 0));
        });

        if (grouped.round_1 && grouped.round_1.length) {
            return buildRoundSequence(grouped.round_1.length).map(round => ({
                key: round.key,
                label: getRoundLabel(round.key, round.matchCount),
                matchCount: round.matchCount,
                slots: fillMatchSlots(grouped[round.key] || [], round.matchCount)
            }));
        }

        const orderedRoundKeys = getOrderedRoundKeys(grouped);

        if (orderedRoundKeys.length) {
            return orderedRoundKeys.map(roundKey => ({
                key: roundKey,
                label: getRoundLabel(roundKey, grouped[roundKey].length),
                matchCount: grouped[roundKey].length,
                slots: fillMatchSlots(grouped[roundKey], grouped[roundKey].length)
            }));
        }

        if (fallbackFirstRoundMatchCount) {
            return buildRoundSequence(fallbackFirstRoundMatchCount).map(round => ({
                key: round.key,
                label: getRoundLabel(round.key, round.matchCount),
                matchCount: round.matchCount,
                slots: fillMatchSlots([], round.matchCount)
            }));
        }

        return [];
    }

    function getOrderedRoundKeys(grouped) {
        const preferred = preferredRounds.filter(key => Array.isArray(grouped[key]) && grouped[key].length);
        const extra = Object.keys(grouped)
            .filter(key => !preferredRounds.includes(key) && Array.isArray(grouped[key]) && grouped[key].length)
            .sort((left, right) => getRoundSortValue(left) - getRoundSortValue(right));

        return preferred.concat(extra);
    }

    function buildRoundSequence(firstRoundMatchCount) {
        const rounds = [{
            key: 'round_1',
            matchCount: firstRoundMatchCount
        }];

        let currentRoundNumber = 1;
        let currentMatchCount = firstRoundMatchCount;

        while (currentMatchCount > 1) {
            const nextMatchCount = Math.ceil(currentMatchCount / 2);
            let nextRoundKey = 'final';

            if (nextMatchCount === 4) {
                nextRoundKey = 'quarter';
            } else if (nextMatchCount === 2) {
                nextRoundKey = 'semi';
            } else if (nextMatchCount > 1) {
                currentRoundNumber += 1;
                nextRoundKey = `round_${currentRoundNumber}`;
            }

            rounds.push({
                key: nextRoundKey,
                matchCount: nextMatchCount
            });

            currentMatchCount = nextMatchCount;
        }

        return rounds;
    }

    function fillMatchSlots(matches, expectedCount) {
        const slots = new Array(expectedCount).fill(null);

        matches.forEach(match => {
            const slotIndex = Math.max((match.match_number || 1) - 1, 0);

            if (slotIndex < slots.length) {
                slots[slotIndex] = match;
            }
        });

        return slots.map((match, index) => ({
            match: match,
            matchNumber: index + 1
        }));
    }

    function buildBoardLayout(rounds) {
        const centers = [];
        const columns = [];
        const firstRoundCount = rounds[0].slots.length;

        for (let roundIndex = 0; roundIndex < rounds.length; roundIndex++) {
            columns[roundIndex] = boardConfig.paddingLeft + roundIndex * (boardConfig.cardWidth + boardConfig.columnGap);
        }

        centers[0] = [];
        for (let slotIndex = 0; slotIndex < firstRoundCount; slotIndex++) {
            centers[0][slotIndex] = boardConfig.headerHeight + (boardConfig.cardHeight / 2) + (slotIndex * (boardConfig.cardHeight + boardConfig.rowGap));
        }

        for (let roundIndex = 1; roundIndex < rounds.length; roundIndex++) {
            centers[roundIndex] = [];

            for (let slotIndex = 0; slotIndex < rounds[roundIndex].slots.length; slotIndex++) {
                const topChild = centers[roundIndex - 1][slotIndex * 2];
                const bottomChild = centers[roundIndex - 1][slotIndex * 2 + 1];

                if (typeof topChild === 'number' && typeof bottomChild === 'number') {
                    centers[roundIndex][slotIndex] = (topChild + bottomChild) / 2;
                } else if (typeof topChild === 'number') {
                    centers[roundIndex][slotIndex] = topChild;
                } else if (typeof bottomChild === 'number') {
                    centers[roundIndex][slotIndex] = bottomChild;
                } else {
                    centers[roundIndex][slotIndex] = boardConfig.headerHeight + (boardConfig.cardHeight / 2);
                }
            }
        }

        return {
            width: columns[columns.length - 1] + boardConfig.cardWidth + boardConfig.paddingRight,
            height: centers[0][centers[0].length - 1] + (boardConfig.cardHeight / 2) + boardConfig.paddingBottom,
            columns: columns,
            centers: centers
        };
    }

    function createConnectorPaths(rounds, layout) {
        let paths = '';

        for (let roundIndex = 0; roundIndex < rounds.length - 1; roundIndex++) {
            for (let slotIndex = 0; slotIndex < rounds[roundIndex].slots.length; slotIndex++) {
                const currentCenterY = layout.centers[roundIndex][slotIndex];
                const nextCenterY = layout.centers[roundIndex + 1][Math.floor(slotIndex / 2)];

                if (typeof currentCenterY !== 'number' || typeof nextCenterY !== 'number') {
                    continue;
                }

                const x1 = layout.columns[roundIndex] + boardConfig.cardWidth;
                const x2 = layout.columns[roundIndex + 1];
                const midX = x1 + ((x2 - x1) / 2);

                paths += `
                    <path d="M ${x1} ${currentCenterY} L ${midX} ${currentCenterY} L ${midX} ${nextCenterY} L ${x2} ${nextCenterY}" />
                `;
            }
        }

        return paths;
    }

    function renderCurrentBracket() {
        const rounds = buildRoundStructure(bracketData, initialRoundMatchCount);

        if (!rounds.length) {
            renderState('empty');
            return;
        }

        renderBracket(rounds);
    }

    function renderBracket(rounds) {
        const container = document.getElementById('bracketContainer');
        const layout = buildBoardLayout(rounds);
        let html = `
            <div class="bracket-board" style="width: ${layout.width}px; height: ${layout.height}px;">
                <svg class="connector-layer" viewBox="0 0 ${layout.width} ${layout.height}" preserveAspectRatio="none">
                    ${createConnectorPaths(rounds, layout)}
                </svg>
        `;

        rounds.forEach((round, roundIndex) => {
            html += `
                <div class="round-heading" style="left: ${layout.columns[roundIndex]}px; width: ${boardConfig.cardWidth}px;">
                    <span class="round-chip">${escapeHtml(round.label)}</span>
                    <p class="round-count">${round.matchCount} คู่ในรอบนี้</p>
                </div>
            `;

            round.slots.forEach((slot, slotIndex) => {
                html += createMatchCard(slot, round.key, layout.columns[roundIndex], layout.centers[roundIndex][slotIndex], roundIndex, rounds);
            });
        });

        html += '</div>';
        container.innerHTML = html;
    }

    function createMatchCard(slot, roundKey, left, centerY, roundIndex, rounds) {
        const top = centerY - (boardConfig.cardHeight / 2);
        const advanceText = getAdvanceText(roundIndex, slot.matchNumber, rounds);
        const slotKey = `${roundKey}-${slot.matchNumber}`;
        const emptyMessage = roundIndex === 0
            ? 'เลือกทีมจาก dropdown เพื่อเริ่มจับคู่รอบแรก'
            : 'เลือกทีมจาก dropdown เพื่อสร้างคู่นี้';

        if (!slot.match) {
            return `
                <article class="match-card is-placeholder" data-slot-key="${escapeAttribute(slotKey)}" style="left: ${left}px; top: ${top}px;">
                    <div class="match-header">
                        <span class="match-number">คู่ที่ ${slot.matchNumber}</span>
                        <span class="match-status pending">รอทีมเข้ารอบ</span>
                    </div>
                    <div class="match-body">
                        <div class="team-row is-tbd">
                            <select class="team-select" onchange="selectSlotTeam('${roundKey}', ${slot.matchNumber}, 'team1_id', this.value)">
                                ${buildInlineTeamOptions('', '')}
                            </select>
                            <span class="team-row-spacer"></span>
                        </div>
                        <div class="team-row is-tbd">
                            <select class="team-select" onchange="selectSlotTeam('${roundKey}', ${slot.matchNumber}, 'team2_id', this.value)">
                                ${buildInlineTeamOptions('', '')}
                            </select>
                            <span class="team-row-spacer"></span>
                        </div>
                    </div>
                    <div class="match-meta is-empty">${emptyMessage}</div>
                    <div class="advance-hint">${escapeHtml(advanceText)}</div>
                    <div class="admin-action-grid">
                        <button type="button" class="match-action-btn" disabled>รอผลจากรอบก่อน</button>
                        <button type="button" class="match-action-btn" disabled>ยังเลือกผู้ชนะไม่ได้</button>
                    </div>
                    <div class="admin-tool-row">
                        <button type="button" class="tool-btn" disabled>กำลังแข่ง</button>
                        <button type="button" class="tool-btn" disabled>ล้างผล</button>
                        <button type="button" class="tool-btn" disabled>รายละเอียด</button>
                    </div>
                </article>
            `;
        }

        const match = slot.match;
        const nextRound = rounds[roundIndex + 1];
        const statusKey = getStatusKey(match.status);
        const isWinner1 = match.winner_id && match.winner_id === match.team1_id;
        const isWinner2 = match.winner_id && match.winner_id === match.team2_id;
        const meta = [];

        if (match.match_time) {
            meta.push(`
                <span class="match-meta-item">
                    <i class="bi bi-clock me-1"></i>${escapeHtml(formatMatchTime(match.match_time))}
                </span>
            `);
        }

        if (match.stream_url) {
            meta.push(`
                <a class="match-meta-link" href="${escapeAttribute(match.stream_url)}" target="_blank" rel="noopener noreferrer">
                    <i class="bi bi-broadcast me-1"></i>ดูสตรีม
                </a>
            `);
        }

        if (match.notes) {
            meta.push(`
                <span class="match-meta-item">
                    <i class="bi bi-card-text me-1"></i>${escapeHtml(match.notes)}
                </span>
            `);
        }

        if (nextRound && match.winner_name) {
            meta.push(`
                <span class="match-meta-item is-highlight">
                    <i class="bi bi-arrow-right-circle me-1"></i>${escapeHtml(match.winner_name)} เข้าสู่ ${escapeHtml(nextRound.label)}
                </span>
            `);
        }

        return `
            <article class="match-card" data-slot-key="${escapeAttribute(slotKey)}" style="left: ${left}px; top: ${top}px;">
                <div class="match-header">
                    <span class="match-number">คู่ที่ ${slot.matchNumber}</span>
                    <span class="match-status ${statusKey}">${getStatusText(statusKey)}</span>
                </div>
                <div class="match-body">
                    <div class="team-row ${isWinner1 ? 'is-winner' : ''} ${!match.team1_id ? 'is-tbd' : ''}">
                        <select class="team-select" onchange="selectMatchTeam(${match.id}, 'team1_id', this.value)">
                            ${buildInlineTeamOptions(match.team1_id, match.team2_id)}
                        </select>
                        ${isWinner1 ? '<i class="bi bi-trophy-fill"></i>' : '<span class="team-row-spacer"></span>'}
                    </div>
                    <div class="team-row ${isWinner2 ? 'is-winner' : ''} ${!match.team2_id ? 'is-tbd' : ''}">
                        <select class="team-select" onchange="selectMatchTeam(${match.id}, 'team2_id', this.value)">
                            ${buildInlineTeamOptions(match.team2_id, match.team1_id)}
                        </select>
                        ${isWinner2 ? '<i class="bi bi-trophy-fill"></i>' : '<span class="team-row-spacer"></span>'}
                    </div>
                </div>
                <div class="match-meta ${meta.length ? '' : 'is-empty'}">
                    ${meta.length ? meta.join('') : 'ยังไม่มีข้อมูลเพิ่มเติม'}
                </div>
                <div class="advance-hint">${escapeHtml(advanceText)}</div>
                <div class="admin-action-grid">
                    <button type="button" class="match-action-btn ${isWinner1 ? 'is-active' : ''}" onclick="setWinner(${match.id}, ${match.team1_id || 'null'})" ${match.team1_id ? '' : 'disabled'}>
                        ${escapeHtml(match.team1_name || 'ทีมที่ 1')} ชนะ
                    </button>
                    <button type="button" class="match-action-btn ${isWinner2 ? 'is-active' : ''}" onclick="setWinner(${match.id}, ${match.team2_id || 'null'})" ${match.team2_id ? '' : 'disabled'}>
                        ${escapeHtml(match.team2_name || 'ทีมที่ 2')} ชนะ
                    </button>
                </div>
                <div class="admin-tool-row">
                    <button type="button" class="tool-btn" onclick="setOngoing(${match.id})">กำลังแข่ง</button>
                    <button type="button" class="tool-btn" onclick="clearWinner(${match.id})">ล้างผล</button>
                    <button type="button" class="tool-btn" onclick="openMatchModal(${match.id})">รายละเอียด</button>
                </div>
            </article>
        `;
    }

    function getAdvanceText(roundIndex, matchNumber, rounds) {
        const nextRound = rounds[roundIndex + 1];

        if (!nextRound) {
            return 'ผู้ชนะของคู่นี้จะเป็นแชมป์รายการ';
        }

        return `ผู้ชนะจะเข้าสู่ ${nextRound.label} คู่ที่ ${Math.ceil(matchNumber / 2)}`;
    }

    function getRoundSortValue(round) {
        if (!round) {
            return 9999;
        }

        if (round.indexOf('round_') === 0) {
            const parsedRound = parseInt(round.split('_')[1], 10);
            return Number.isNaN(parsedRound) ? 999 : parsedRound;
        }

        if (round === 'quarter') {
            return 1000;
        }

        if (round === 'semi') {
            return 1001;
        }

        if (round === 'final') {
            return 1002;
        }

        return 9000;
    }

    function getRoundLabel(roundKey, matchCount) {
        return roundTextMap[roundKey] || `รอบ ${matchCount * 2} ทีม`;
    }

    function getStatusKey(status) {
        if (status === 'ongoing' || status === 'completed') {
            return status;
        }

        return 'pending';
    }

    function getStatusText(status) {
        const textMap = {
            pending: 'รอแข่ง',
            ongoing: 'กำลังแข่ง',
            completed: 'จบแล้ว'
        };

        return textMap[status] || 'รอแข่ง';
    }

    function formatMatchTime(value) {
        return new Date(value).toLocaleString('th-TH', {
            day: 'numeric',
            month: 'short',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function toDateTimeLocalValue(value) {
        if (!value) {
            return '';
        }

        const date = new Date(value);
        const timezoneOffset = date.getTimezoneOffset() * 60000;
        return new Date(date.getTime() - timezoneOffset).toISOString().slice(0, 16);
    }

    function populateTeamSelects() {
        const options = teamsList
            .map(team => `<option value="${team.id}">${escapeHtml(team.team_name)}</option>`)
            .join('');

        document.getElementById('team1Id').innerHTML = '<option value="">-- ว่าง --</option>' + options;
        document.getElementById('team2Id').innerHTML = '<option value="">-- ว่าง --</option>' + options;
    }

    function buildInlineTeamOptions(selectedId, excludedId) {
        const selectedValue = selectedId ? String(selectedId) : '';
        const excludedValue = excludedId ? String(excludedId) : '';
        let options = '<option value="">-- ว่าง --</option>';

        teamsList.forEach(team => {
            const teamId = String(team.id);

            if (excludedValue && teamId === excludedValue && teamId !== selectedValue) {
                return;
            }

            options += `<option value="${teamId}" ${teamId === selectedValue ? 'selected' : ''}>${escapeHtml(team.team_name)}</option>`;
        });

        return options;
    }

    function getExistingRoundMatchCount(roundKey) {
        const matchesInRound = bracketData.filter(match => match.round === roundKey).length;

        if (matchesInRound) {
            return matchesInRound;
        }

        if (initialRoundMatchCount) {
            const round = buildRoundSequence(initialRoundMatchCount).find(item => item.key === roundKey);

            if (round) {
                return round.matchCount;
            }
        }

        return 1;
    }

    function getExpectedRoundMatchCount(roundKey) {
        const firstRoundMatchCount = bracketData.filter(match => match.round === 'round_1').length;

        if (!firstRoundMatchCount) {
            return getExistingRoundMatchCount(roundKey);
        }

        const round = buildRoundSequence(firstRoundMatchCount).find(item => item.key === roundKey);
        return round ? round.matchCount : getExistingRoundMatchCount(roundKey);
    }

    function getMatchById(matchId) {
        return bracketData.find(match => match.id === matchId);
    }

    function getMatchBySlot(roundKey, matchNumber) {
        return bracketData.find(match => match.round === roundKey && match.match_number === matchNumber);
    }

    function sortBracketMatches(matches) {
        matches.sort((left, right) => {
            const roundDiff = getRoundSortValue(left.round) - getRoundSortValue(right.round);

            if (roundDiff !== 0) {
                return roundDiff;
            }

            return (left.match_number || 0) - (right.match_number || 0);
        });
    }

    function upsertBracketMatches(matches) {
        const merged = new Map(bracketData.map(match => [match.id, match]));

        matches.forEach(match => {
            merged.set(match.id, match);
        });

        bracketData = Array.from(merged.values());
        sortBracketMatches(bracketData);
    }

    function patchBracketDom(updatedMatches, deletedMatchId) {
        if (deletedMatchId || !updatedMatches.length) {
            renderCurrentBracket();
            return;
        }

        const container = document.getElementById('bracketContainer');
        const board = container.querySelector('.bracket-board');

        if (!board) {
            renderCurrentBracket();
            return;
        }

        const rounds = buildRoundStructure(bracketData, initialRoundMatchCount);

        if (!rounds.length) {
            renderState('empty');
            return;
        }

        const layout = buildBoardLayout(rounds);
        let requiresFullRender = false;

        updatedMatches.forEach(match => {
            const roundIndex = rounds.findIndex(round => round.key === match.round);

            if (roundIndex === -1) {
                requiresFullRender = true;
                return;
            }

            const slotIndex = rounds[roundIndex].slots.findIndex(slot => slot.matchNumber === match.match_number);

            if (slotIndex === -1) {
                requiresFullRender = true;
                return;
            }

            const slotKey = `${match.round}-${match.match_number}`;
            const card = board.querySelector(`[data-slot-key="${slotKey}"]`);

            if (!card) {
                requiresFullRender = true;
                return;
            }

            card.outerHTML = createMatchCard(
                rounds[roundIndex].slots[slotIndex],
                rounds[roundIndex].key,
                layout.columns[roundIndex],
                layout.centers[roundIndex][slotIndex],
                roundIndex,
                rounds
            );
        });

        if (requiresFullRender) {
            renderCurrentBracket();
        }
    }

    function applyBracketChanges(data) {
        if (!data) {
            renderCurrentBracket();
            return;
        }

        if (Array.isArray(data.matches)) {
            bracketData = data.matches;
            sortBracketMatches(bracketData);
            renderCurrentBracket();
            return;
        }

        const deletedMatchId = data.deleted_match_id || null;

        if (deletedMatchId) {
            bracketData = bracketData.filter(match => match.id !== deletedMatchId);
        }

        if (Array.isArray(data.updated_matches) && data.updated_matches.length) {
            upsertBracketMatches(data.updated_matches);
        } else {
            sortBracketMatches(bracketData);
        }

        patchBracketDom(data.updated_matches || [], deletedMatchId);
    }

    function buildTeamSelectionOverrides(matchLike, teamField, value) {
        const selectedTeamId = value ? parseInt(value, 10) : null;
        const overrides = {
            team1_id: teamField === 'team1_id' ? selectedTeamId : (matchLike.team1_id || null),
            team2_id: teamField === 'team2_id' ? selectedTeamId : (matchLike.team2_id || null)
        };

        if (overrides.team1_id && overrides.team2_id && overrides.team1_id === overrides.team2_id) {
            if (teamField === 'team1_id') {
                overrides.team2_id = null;
            } else {
                overrides.team1_id = null;
            }
        }

        if (matchLike.winner_id && matchLike.winner_id !== overrides.team1_id && matchLike.winner_id !== overrides.team2_id) {
            overrides.winner_id = null;
        }

        const nextWinnerId = Object.prototype.hasOwnProperty.call(overrides, 'winner_id')
            ? overrides.winner_id
            : (matchLike.winner_id || null);

        if ((matchLike.team1_id || null) === (overrides.team1_id || null)
            && (matchLike.team2_id || null) === (overrides.team2_id || null)
            && (matchLike.winner_id || null) === nextWinnerId) {
            return null;
        }

        return overrides;
    }

    function submitNewMatch(roundKey, matchNumber, overrides) {
        fetch('/api/admin/bracket/new', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                round: roundKey,
                match_number: matchNumber,
                team1_id: null,
                team2_id: null,
                winner_id: null,
                status: 'pending',
                match_time: null,
                stream_url: '',
                notes: '',
                ...overrides
            })
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    applyBracketChanges(result.data);
                } else {
                    alert(result.message || 'เกิดข้อผิดพลาด');
                }
            }, () => {
                alert('บันทึกข้อมูลคู่แข่งขันไม่สำเร็จ');
            });
    }

    function selectMatchTeam(matchId, teamField, value) {
        const match = getMatchById(matchId);

        if (!match) {
            return;
        }

        const overrides = buildTeamSelectionOverrides(match, teamField, value);

        if (!overrides) {
            return;
        }

        submitMatchUpdate(matchId, overrides);
    }

    function selectSlotTeam(roundKey, matchNumber, teamField, value) {
        const existingMatch = getMatchBySlot(roundKey, matchNumber);

        if (existingMatch) {
            selectMatchTeam(existingMatch.id, teamField, value);
            return;
        }

        const overrides = buildTeamSelectionOverrides({
            team1_id: null,
            team2_id: null,
            winner_id: null
        }, teamField, value);

        if (!overrides) {
            return;
        }

        submitNewMatch(roundKey, matchNumber, overrides);
    }

    function enableGrabScroll(viewport) {
        if (!viewport) {
            return;
        }

        const dragState = {
            isPointerDown: false,
            isDragging: false,
            startX: 0,
            startY: 0,
            startScrollLeft: 0,
            startScrollTop: 0,
            startPageScrollTop: 0
        };
        const interactiveSelector = 'a, button, input, select, textarea, label, summary, [role="button"]';

        viewport.addEventListener('mousedown', event => {
            if (event.button !== 0 || event.target.closest(interactiveSelector)) {
                return;
            }

            dragState.isPointerDown = true;
            dragState.isDragging = false;
            dragState.startX = event.clientX;
            dragState.startY = event.clientY;
            dragState.startScrollLeft = viewport.scrollLeft;
            dragState.startScrollTop = viewport.scrollTop;
            dragState.startPageScrollTop = window.scrollY;
            viewport.classList.add('is-grab-ready');
        });

        window.addEventListener('mousemove', event => {
            if (!dragState.isPointerDown) {
                return;
            }

            const deltaX = event.clientX - dragState.startX;
            const deltaY = event.clientY - dragState.startY;

            if (!dragState.isDragging && Math.abs(deltaX) + Math.abs(deltaY) < 6) {
                return;
            }

            dragState.isDragging = true;
            viewport.classList.add('is-grabbing');
            document.body.classList.add('is-bracket-dragging');
            viewport.scrollLeft = dragState.startScrollLeft - deltaX;

            if (viewport.scrollHeight > viewport.clientHeight) {
                viewport.scrollTop = dragState.startScrollTop - deltaY;
            } else {
                window.scrollTo(window.scrollX, dragState.startPageScrollTop - deltaY);
            }

            event.preventDefault();
        });

        window.addEventListener('mouseup', () => {
            if (!dragState.isPointerDown) {
                return;
            }

            dragState.isPointerDown = false;
            dragState.isDragging = false;
            viewport.classList.remove('is-grab-ready', 'is-grabbing');
            document.body.classList.remove('is-bracket-dragging');
        });

        viewport.addEventListener('dragstart', event => {
            if (dragState.isPointerDown) {
                event.preventDefault();
            }
        });
    }

    function getUpdatePayload(match, overrides) {
        return {
            round: match.round,
            team1_id: match.team1_id || null,
            team2_id: match.team2_id || null,
            winner_id: match.winner_id || null,
            status: match.status || 'pending',
            match_time: match.match_time ? toDateTimeLocalValue(match.match_time) : null,
            stream_url: match.stream_url || '',
            notes: match.notes || '',
            ...overrides
        };
    }

    function submitMatchUpdate(matchId, overrides) {
        const match = getMatchById(matchId);

        if (!match) {
            return;
        }

        fetch(`/api/admin/bracket/${matchId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(getUpdatePayload(match, overrides))
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    applyBracketChanges(result.data);
                } else {
                    alert(result.message || 'เกิดข้อผิดพลาด');
                }
            }, () => {
                alert('บันทึกผลการแข่งขันไม่สำเร็จ');
            });
    }

    function setWinner(matchId, winnerId) {
        if (!winnerId) {
            return;
        }

        submitMatchUpdate(matchId, {
            winner_id: winnerId,
            status: 'completed'
        });
    }

    function clearWinner(matchId) {
        submitMatchUpdate(matchId, {
            winner_id: null,
            status: 'pending'
        });
    }

    function setOngoing(matchId) {
        submitMatchUpdate(matchId, {
            winner_id: null,
            status: 'ongoing'
        });
    }

    function openMatchModal(matchId) {
        const match = getMatchById(matchId);

        if (!match) {
            return;
        }

        document.getElementById('matchId').value = match.id;
        document.getElementById('matchRound').value = match.round;
        document.getElementById('matchRoundLabel').value = getRoundLabel(match.round, getExpectedRoundMatchCount(match.round));
        document.getElementById('team1Id').value = match.team1_id || '';
        document.getElementById('team2Id').value = match.team2_id || '';
        document.getElementById('matchStatus').value = getStatusKey(match.status);
        document.getElementById('matchTime').value = toDateTimeLocalValue(match.match_time);
        document.getElementById('matchStream').value = match.stream_url || '';
        document.getElementById('matchNotes').value = match.notes || '';

        updateWinnerOptions();
        document.getElementById('winnerId').value = match.winner_id || '';

        new bootstrap.Modal(document.getElementById('matchModal')).show();
    }

    function updateWinnerOptions() {
        const team1Id = document.getElementById('team1Id').value;
        const team2Id = document.getElementById('team2Id').value;
        const team1Name = teamsList.find(team => team.id == team1Id)?.team_name || 'ทีมที่ 1';
        const team2Name = teamsList.find(team => team.id == team2Id)?.team_name || 'ทีมที่ 2';
        let options = '<option value="">-- ยังไม่มี --</option>';

        if (team1Id) {
            options += `<option value="${team1Id}">${escapeHtml(team1Name)}</option>`;
        }

        if (team2Id) {
            options += `<option value="${team2Id}">${escapeHtml(team2Name)}</option>`;
        }

        document.getElementById('winnerId').innerHTML = options;
    }

    document.getElementById('team1Id').addEventListener('change', updateWinnerOptions);
    document.getElementById('team2Id').addEventListener('change', updateWinnerOptions);

    function saveMatch() {
        const matchId = document.getElementById('matchId').value;
        const match = getMatchById(parseInt(matchId, 10));

        if (!match) {
            return;
        }

        fetch(`/api/admin/bracket/${matchId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                round: document.getElementById('matchRound').value,
                team1_id: document.getElementById('team1Id').value || null,
                team2_id: document.getElementById('team2Id').value || null,
                winner_id: document.getElementById('winnerId').value || null,
                status: document.getElementById('matchStatus').value,
                match_time: document.getElementById('matchTime').value || null,
                stream_url: document.getElementById('matchStream').value,
                notes: document.getElementById('matchNotes').value
            })
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('matchModal')).hide();
                    applyBracketChanges(result.data);
                } else {
                    alert(result.message || 'เกิดข้อผิดพลาด');
                }
            }, () => {
                alert('บันทึกข้อมูลคู่แข่งขันไม่สำเร็จ');
            });
    }

    function deleteMatch() {
        const matchId = document.getElementById('matchId').value;

        if (!matchId || !confirm('ยืนยันการลบคู่นี้?')) {
            return;
        }

        fetch(`/api/admin/bracket/${matchId}`, {
            method: 'DELETE',
            credentials: 'include'
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('matchModal')).hide();
                    applyBracketChanges(result.data);
                } else {
                    alert(result.message || 'เกิดข้อผิดพลาด');
                }
            }, () => {
                alert('ลบคู่แข่งขันไม่สำเร็จ');
            });
    }

    function generateBracket() {
        if (!confirm('สร้างตารางแข่งขันอัตโนมัติจากทีมที่อนุมัติแล้ว?')) {
            return;
        }

        fetch('/api/admin/bracket/generate', {
            method: 'POST',
            credentials: 'include'
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    applyBracketChanges(result.data);
                } else {
