                }
            }, () => {
                alert('สร้างตารางแข่งขันไม่สำเร็จ');
            });
    }

    function resetBracket() {
        if (!confirm('รีเซ็ตการจับคู่ทั้งหมดใช่ไหม? ระบบจะลบ bracket ทุกคู่เพื่อให้จัดสายใหม่ได้ โดยจะไม่ลบผู้สมัครหรือรายชื่อทีม')) {
            return;
        }

        fetch('/api/admin/bracket/reset', {
            method: 'POST',
            credentials: 'include'
        }).then(res => res.json())
            .then(result => {
                if (result.success) {
                    applyBracketChanges(result.data);
                } else {
                    alert(result.message || 'เกิดข้อผิดพลาด');
                }
            }, () => {
                alert('รีเซ็ตการจับคู่ไม่สำเร็จ');
            });
    }

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function escapeAttribute(value) {
        return escapeHtml(value).replace(/`/g, '&#96;');
    }
</script>

