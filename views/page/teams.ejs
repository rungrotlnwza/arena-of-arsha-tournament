            <i class="bi bi-diagram-3-fill me-3"></i>ตารางการแข่งขัน
        </h2>
        <div class="bracket-container" style="overflow-x: auto; padding: 20px 0;">
            <div class="bracket d-flex justify-content-center" style="min-width: 800px;">
                <!-- Round 1 -->
                <div class="bracket-round d-flex flex-column justify-content-center mx-3">
