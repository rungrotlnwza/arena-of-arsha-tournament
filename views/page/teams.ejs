                    <div class="bracket-match my-5">
                        <div class="match-card" style="background: var(--card-bg); border: 2px solid var(--primary-gold); border-radius: 12px; width: 180px; overflow: hidden;">
                            <div class="match-team p-3" style="border-bottom: 1px solid rgba(255,215,0,0.1); color: #ccc;">TBD</div>
