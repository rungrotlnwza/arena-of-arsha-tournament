                    <div class="bracket-match my-2">
                        <div class="match-card" style="background: var(--card-bg); border: 1px solid rgba(255,215,0,0.2); border-radius: 12px; width: 180px; overflow: hidden;">
                            <div class="match-team p-3" style="border-bottom: 1px solid rgba(255,215,0,0.1); color: #ccc;">TBD</div>
                            <div class="match-team p-3" style="color: #ccc;">TBD</div>
                        </div>
                    </div>
