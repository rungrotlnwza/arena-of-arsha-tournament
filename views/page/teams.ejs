<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-people-fill me-3"></i>ตารางทีมแข่ง</h1>
        <p class="page-subtitle">รายชื่อทีมที่เข้าร่วมการแข่งขัน Arena of Arsha Tournament</p>
    </div>
</header>

<!-- Stats Section -->
<section class="stats-section py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div style="font-size: 3rem; font-weight: 700; color: var(--primary-gold);">0</div>
                    <div style="color: #888;">ทีมที่สมัคร</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div style="font-size: 3rem; font-weight: 700; color: var(--primary-gold);">0</div>
                    <div style="color: #888;">ผู้เล่นทั้งหมด</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div style="font-size: 3rem; font-weight: 700; color: var(--primary-gold);">32</div>
                    <div style="color: #888;">ที่นั่งว่าง</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Empty State -->
<section class="teams-section py-4">
    <div class="container">
        <div class="empty-state text-center py-5">
            <i class="bi bi-people" style="font-size: 5rem; color: rgba(255,215,0,0.3);"></i>
            <h3 class="mt-3" style="color: #888;">ยังไม่มีทีมที่ลงทะเบียน</h3>
            <p style="color: #666;">รอการอัปเดตรายชื่อทีมเร็วๆ นี้</p>
            <a href="/register" class="btn btn-lg mt-3" style="background: var(--primary-gold); color: #000; padding: 12px 35px; border-radius: 50px; font-weight: 600;">
                <i class="bi bi-lightning-charge-fill me-2"></i>สมัครเข้าแข่งขัน
            </a>
        </div>
    </div>
</section>

<!-- Tournament Bracket -->
