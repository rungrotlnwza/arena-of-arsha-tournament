<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <div class="live-badge-large d-inline-flex align-items-center">
            <span class="live-dot-large"></span>
            LIVE STREAMING
        </div>
        <h1 class="page-title"><i class="bi bi-broadcast-pin me-3"></i>ช่องถ่ายทอดสด</h1>
        <p class="page-subtitle">รับชมการแข่งขัน Arena of Arsha Tournament สดๆ ได้ที่นี่</p>
    </div>
</header>

<!-- Video Section -->
<section class="video-section py-4">
    <div class="container">
        <div class="video-container" style="background: var(--card-bg); border: 2px solid rgba(255,215,0,0.2); border-radius: 20px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.5);">
            <div class="video-wrapper" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <% if (isLive) { %>
                    <iframe src="https://player.twitch.tv/?channel=NHON_THESTAR&parent=<%= domain %>" frameborder="0" allowfullscreen="true" scrolling="no" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
                    </iframe>
                    <% } else { %>
                        <div class="video-placeholder d-flex flex-column align-items-center justify-content-center" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(10,10,30,0.95) 0%, rgba(0,0,0,0.98) 100%);">
                            <i class="bi bi-camera-video-off" style="font-size: 5rem; color: rgba(255,215,0,0.3);"></i>
                            <h3 class="mt-3" style="color: #888;">รอการถ่ายทอดสด</h3>
                            <p style="color: #666;">การแข่งขันจะเริ่มถ่ายทอดสดในวันที่ 00/00/0000 เวลา 00.00น.</p>
                        </div>
                        <% } %>
            </div>
            <div class="stream-info p-4" style="background: rgba(0,0,0,0.3);">
                <h3 class="stream-title" style="color: var(--primary-gold); font-size: 1.5rem; font-weight: 600; margin-bottom: 10px;">
                    <i class="bi bi-trophy-fill me-2"></i>
                    Arena of Arsha - The All Random Tournament
                </h3>
                <div class="stream-meta d-flex flex-wrap gap-4" style="color: #888;">
                    <span><i class="bi bi-twitch me-2" style="color: var(--primary-gold);"></i> NHON_THESTAR</span>
                    <span><i class="bi bi-calendar3 me-2" style="color: var(--primary-gold);"></i> 00/00/0000</span>
                    <span><i class="bi bi-clock me-2" style="color: var(--primary-gold);"></i> 00.00 น. เป็นต้นไป</span>
                    <span><i class="bi bi-people me-2" style="color: var(--primary-gold);"></i>
                        <%= stats.viewers || 'รอการอัปเดต' %>
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Social Links -->
<section class="social-section py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="social-card twitch">
                    <div class="social-icon">
                        <i class="bi bi-twitch"></i>
                    </div>
                    <h4 class="social-name">Twitch</h4>
                    <p class="social-handle">NHON_THESTAR</p>
                    <a href="https://twitch.tv/NHON_THESTAR" target="_blank" class="social-btn">
                        <i class="bi bi-box-arrow-up-right me-1"></i> ติดตาม
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="social-card youtube">
                    <div class="social-icon">
                        <i class="bi bi-youtube"></i>
                    </div>
                    <h4 class="social-name">YouTube</h4>
                    <p class="social-handle">NHON THESTAR</p>
                    <a href="#" target="_blank" class="social-btn">
                        <i class="bi bi-bell-fill me-1"></i> กดติดตาม
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="social-card discord">
                    <div class="social-icon">
                        <i class="bi bi-discord"></i>
                    </div>
                    <h4 class="social-name">Discord</h4>
                    <p class="social-handle">AOA Tournament</p>
                    <a href="#" target="_blank" class="social-btn">
                        <i class="bi bi-plus-lg me-1"></i> เข้าร่วม
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="social-card facebook">
                    <div class="social-icon">
                        <i class="bi bi-facebook"></i>
                    </div>
                    <h4 class="social-name">Facebook</h4>
                    <p class="social-handle">Arena of Arsha TH</p>
                    <a href="#" target="_blank" class="social-btn">
                        <i class="bi bi-hand-thumbs-up-fill me-1"></i> ถูกใจ
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Countdown Section -->
<section class="countdown-section py-5" style="background: linear-gradient(135deg, rgba(255,215,0,0.1) 0%, rgba(0,0,0,0.3) 100%); text-align: center;">
    <div class="container">
        <h2 class="countdown-title mb-4" style="color: var(--primary-gold); font-size: 1.8rem; font-weight: 600;">
            <i class="bi bi-clock-history me-2"></i>
            นับถอยหลังสู่การแข่งขัน
        </h2>
        <div class="countdown d-flex justify-content-center gap-4 flex-wrap">
            <div class="countdown-item">
                <div class="countdown-number" id="days">00</div>
                <div class="countdown-label">วัน</div>
            </div>
            <div class="countdown-item">
                <div class="countdown-number" id="hours">00</div>
                <div class="countdown-label">ชั่วโมง</div>
            </div>
            <div class="countdown-item">
                <div class="countdown-number" id="minutes">00</div>
                <div class="countdown-label">นาที</div>
            </div>
            <div class="countdown-item">
                <div class="countdown-number" id="seconds">00</div>
                <div class="countdown-label">วินาที</div>
            </div>
        </div>
    </div>
</section>

<!-- Schedule Section -->
<section class="schedule-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5" style="color: var(--primary-gold); font-weight: 700; font-size: 2rem;">
            <i class="bi bi-calendar-week-fill me-3"></i>ตารางการถ่ายทอดสด
        </h2>
        <div class="schedule-card" style="background: var(--card-bg); border: 1px solid rgba(255,215,0,0.15); border-radius: 20px; padding: 30px;">
            <% const schedule=[ { time: '18.00' , date: '00/00/0000' , title: 'Pre-Show & แนะนำทีม' , desc: 'แนะนำทีมผู้เข้าแข่งขันและประกาศอาชีพที่สุ่มได้' , status: 'upcoming' }, { time: '19.00' , date: '00/00/0000' , title: 'รอบที่ 1 - Round of 16' , desc: 'เริ่มการแข่งขันรอบแรก 16 ทีมสุดท้าย' , status: 'upcoming' }, { time: '20.30' , date: '00/00/0000' , title: 'รอบ 8 ทีม - Quarter Finals' , desc: 'คัดเหลือ 4 ทีมสุดท้ายเข้ารอบรองชนะเลิศ' , status: 'upcoming' }, { time: '21.30' , date: '00/00/0000' , title: 'รอบรองชนะเลิศ - Semi Finals' , desc: '4 ทีมสุดท้ายชิงตั๋วเข้าชิงชนะเลิศ' , status: 'upcoming' }, { time: '22.30' , date: '00/00/0000' , title: 'รอบชิงชนะเลิศ - Grand Finals' , desc: 'คู่ชิงชนะเลิศชิงเงินรางวัล 40,000 บาท!' , status: 'upcoming' } ]; %>
                <% schedule.forEach((item, index)=> { %>
                    <div class="schedule-item d-flex align-items-center py-4" style="border-bottom: <%= index < schedule.length - 1 ? '1px solid rgba(255,215,0,0.1)' : 'none' %>;">
                        <div class="schedule-time text-center" style="min-width: 100px;">
                            <div style="color: var(--primary-gold); font-weight: 700; font-size: 1.3rem;">
                                <%= item.time %>
                            </div>
                            <div style="color: #888; font-size: 0.9rem;">
                                <%= item.date %>
                            </div>
                        </div>
                        <div class="schedule-content flex-1 px-4">
                            <h4 style="color: #fff; font-weight: 600; margin-bottom: 5px;">
                                <%= item.title %>
                            </h4>
                            <p style="color: #888; margin: 0;">
                                <%= item.desc %>
                            </p>
                        </div>
                        <span class="schedule-status px-3 py-2 rounded-pill" style="font-size: 0.85rem; font-weight: 500;
                        <%= item.status === 'live' ? 'background: rgba(255,0,0,0.2); color: #ff4444; border: 1px solid rgba(255,0,0,0.3);' : 
                           item.status === 'ended' ? 'background: rgba(40,167,69,0.1); color: #28a745; border: 1px solid rgba(40,167,69,0.3);' :
                           'background: rgba(255,215,0,0.1); color: var(--primary-gold); border: 1px solid rgba(255,215,0,0.3);' %>">
                            <%= item.status==='live' ? '🔴 LIVE' : item.status==='ended' ? '✓ จบแล้ว' : 'รอการถ่ายทอด' %>
                        </span>
                    </div>
                    <% }); %>
        </div>
    </div>
</section>

<script>
    // Countdown Timer
    const targetDate = new Date('2024-12-31T18:00:00').getTime();

    function updateCountdown() {
        const now = new Date().getTime();
        const distance = targetDate - now;

        if (distance > 0) {
            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
        }
    }

    setInterval(updateCountdown, 1000);
    updateCountdown();
</script>