<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-broadcast me-3"></i>ถ่ายทอดสด</h1>
        <p class="page-subtitle">รับชมการแข่งขัน Arena of Arsha The All Random Tournament สดๆ ที่นี่</p>
    </div>
</header>

<!-- Live Stream Container -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Stream Container -->
                <div class="stream-container mb-4" style="background: #000; border-radius: 15px; overflow: hidden; border: 2px solid var(--primary-gold);">
                    <iframe id="twitchStream" src="" frameborder="0" allowfullscreen="true" scrolling="no" height="500" width="100%">
                    </iframe>
                </div>

                <script>
                    // Set Twitch embed parent dynamically based on current hostname
                    const hostname = window.location.hostname || 'localhost';
                    document.getElementById('twitchStream').src =
                        'https://player.twitch.tv/?channel=nhon_thestar&parent=' + hostname;
                </script>

                <!-- Info Cards -->
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="text-center p-4 rounded" style="background: rgba(30,30,30,0.9); border: 1px solid var(--border-color);">
                            <i class="bi bi-calendar-event fs-2 mb-2 d-block" style="color: var(--primary-gold);"></i>
                            <h5 style="color: #fff;">วันแข่งขัน</h5>
                            <p class="mb-0 text-light">10 และ 17 พฤษภาคม 2569</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center p-4 rounded" style="background: rgba(30,30,30,0.9); border: 1px solid var(--border-color);">
