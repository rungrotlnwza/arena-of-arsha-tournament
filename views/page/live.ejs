                    </div>
                    <div class="col-md-4">
                        <div class="text-center p-4 rounded" style="background: rgba(30,30,30,0.9); border: 1px solid var(--border-color);">
                            <i class="bi bi-trophy fs-2 mb-2 d-block" style="color: var(--primary-gold);"></i>
                            <h5 style="color: #fff;">รางวัลรวม</h5>
                            <p class="mb-0 text-light">60,000 บาท</p>
