        <!-- Important Notice -->
        <div class="rule-card text-center" style="background: linear-gradient(135deg, rgba(255, 215, 0, 0.1) 0%, rgba(255, 183, 0, 0.05) 100%); border: 2px solid var(--primary-gold);">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-warning mb-3"></i>
            <h3 style="color: var(--primary-gold);">หมายเหตุสำคัญ</h3>
            <p style="color: #bbb;">
                หากทีมไหนไม่มาร่วมการแข่งขัน ทีมงานจะขอตัดสิทธิการมอบรางวัล<br>
                ทีมงานจะทำการเติมเงิน Razer Gold ให้กับ ID ผู้เข้าแข่งขัน หลังจากการแข่งขันจบลง<br>
                การตัดสินของทีมงานถือเป็นที่สิ้นสุด
            </p>
        </div>

        <!-- CTA Section -->
        <div class="text-center py-5">
            <h2 class="mb-4" style="color: var(--primary-gold);">พร้อมที่จะแข่งขันแล้วหรือยัง?</h2>
            <p class="mb-4" style="color: #aaa;">สมัครเข้าร่วมการแข่งขันและคว้าเงินรางวัลกว่า 70,000 บาท!</p>
            <a href="/register" class="btn btn-custom btn-lg">
                <i class="bi bi-lightning-charge-fill me-2"></i>สมัครเข้าแข่งทันที
            </a>
        </div>
    </div>
</section>