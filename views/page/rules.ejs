<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-journal-text me-3"></i>กติกาการเข้าร่วมแข่งขัน</h1>
        <p class="page-subtitle">กรุณาอ่านกติกาอย่างละเอียดก่อนสมัครเข้าร่วมการแข่งขัน</p>
    </div>
</header>

<!-- Rules Section -->
<section class="rules-section py-5">
    <div class="container">
        <!-- Team Rules -->
        <div class="rule-card">
            <div class="rule-number">01</div>
            <h3 class="rule-title">เงื่อนไขการสมัครทีม</h3>
            <div class="rule-content">
                <ul>
                    <li>ทีมต้องมีผู้เล่น <strong>2 คน</strong> (ผู้เข้าร่วมต้องหาคู่ของตนเองมา)</li>
                    <li>ผู้เล่นแต่ละคนต้องมีบัญชี Black Desert Online ที่ใช้งานได้จริง</li>
                    <li>แต่ละผู้เล่นสามารถเข้าร่วมได้เพียง 1 ทีมเท่านั้น</li>
                    <li>ทีมที่สมัครต้องมีชื่อทีมที่ไม่หยาบคายหรือละเมิดลิขสิทธิ์</li>
                </ul>
            </div>
        </div>

        <!-- Character Rules -->
        <div class="rule-card">
            <div class="rule-number">02</div>
            <h3 class="rule-title">กติกาอาชีพ (Class)</h3>
            <div class="rule-content">
                <ul>
                    <li><strong>อาชีพของผู้เข้าแข่งขันจะถูกสุ่มโดยระบบของทีมงาน</strong></li>
                    <li>ผู้เข้าร่วมไม่สามารถเลือกอาชีพที่ต้องการได้</li>
                    <li>อาชีพจะถูกสุ่มและประกาศก่อนการแข่งขันเริ่มต้น</li>
                    <li>ผู้เล่นต้องเตรียมตัวละครตามอาชีพที่ได้รับมอบหมาย</li>
                    <li>หากพบว่ามีการใช้อาชีพที่ไม่ตรงตามที่สุ่มได้ ทีมนั้นจะถูกปรับแพ้ทันที</li>
                </ul>
            </div>
        </div>

        <!-- Match Rules -->
        <div class="rule-card">
            <div class="rule-number">03</div>
            <h3 class="rule-title">รูปแบบการแข่งขัน</h3>
            <div class="rule-content">
                <ul>
                    <li>แข่งขันแบบ <strong>2v2 Team Battle</strong> ใน Arena of Arsha</li>
                    <li>ระบบการจับคู่แบบสุ่ม (Random Bracket)</li>
                    <li>แต่ละรอบแข่งขันแบบ Best of 3 (ชนะ 2 ใน 3 เกม)</li>
                    <li>รอบรองชนะเลิศและชิงชนะเลิศ แข่งขันแบบ Best of 5</li>
                    <li>หากเกิดปัญหาด้านเทคนิค ให้แจ้งกรรมการทันที</li>
                </ul>
            </div>
        </div>

        <!-- Schedule -->
        <div class="rule-card">
            <div class="rule-number">04</div>
            <h3 class="rule-title">กำหนดการแข่งขัน</h3>
            <div class="rule-content">
                <ul>
                    <li><strong>วันที่ 00/00/0000</strong> - เปิดรับสมัคร</li>
                    <li><strong>วันที่ 00/00/0000</strong> - ปิดรับสมัคร</li>
                    <li><strong>วันที่ 00/00/0000</strong> - ประกาศอาชีพที่สุ่มได้</li>
                    <li><strong>วันที่ 00/00/0000 เวลา 00.00น.</strong> - เริ่มการแข่งขัน</li>
                    <li>ผู้เข้าแข่งต้องเข้าร่วม 30 นาทีก่อนเวลาแข่งขัน</li>
                </ul>
            </div>
        </div>

        <!-- Conduct Rules -->
        <div class="rule-card">
            <div class="rule-number">05</div>
            <h3 class="rule-title">จริยธรรมการแข่งขัน</h3>
            <div class="rule-content">
                <ul>
                    <li>ห้ามใช้โปรแกรมโกง (Cheating) หรือบัคในเกม</li>
                    <li>ห้ามมีพฤติกรรมกลั่นแกล้ง (Toxic) หรือหยาบคาย</li>
                    <li>ต้องเชื่อฟังคำตัดสินของกรรมการ</li>
                    <li>หากพบการกระทำผิดกติกา ทีมงานมีสิทธิ์ตัดสิทธิ์ทีมนั้นทันที</li>
                    <li>การตัดสินของกรรมการถือเป็นที่สิ้นสุด</li>
                </ul>
            </div>
        </div>

        <!-- Important Notice -->
        <div class="rule-card text-center" style="background: linear-gradient(135deg, rgba(255, 215, 0, 0.1) 0%, rgba(255, 183, 0, 0.05) 100%); border: 2px solid var(--primary-gold);">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-warning mb-3"></i>
            <h3 style="color: var(--primary-gold);">หมายเหตุสำคัญ</h3>
            <p style="color: #bbb;">ทีมงานขอสงวนสิทธิ์ในการเปลี่ยนแปลงกติกา วันเวลา หรือรายละเอียดอื่นๆ โดยไม่ต้องแจ้งให้ทราบล่วงหน้า<br>
                หากมีข้อสงสัยเพิ่มเติม สามารถติดต่อทีมงานผ่านช่องทางที่ระบุในหน้าถ่ายทอดสด</p>
        </div>

        <!-- Prize Section -->
        <h2 class="text-center mb-4" style="color: var(--primary-gold); font-weight: 700;">
            <i class="bi bi-trophy me-2"></i>เงินรางวัล
        </h2>
        <div class="prize-table mb-5">
            <div class="prize-header">
                <i class="bi bi-award-fill me-2"></i>รางวัลรวม 40,000 บาท
            </div>
            <div class="prize-item">
                <div class="prize-rank rank-1">1</div>
                <div class="prize-amount">20,000 บาท</div>
                <div class="prize-desc">รางวัลชนะเลิศ</div>
            </div>
            <div class="prize-item">
                <div class="prize-rank rank-2">2</div>
                <div class="prize-amount">12,000 บาท</div>
                <div class="prize-desc">รองชนะเลิศอันดับ 1</div>
            </div>
            <div class="prize-item">
                <div class="prize-rank rank-3">3</div>
                <div class="prize-amount">8,000 บาท</div>
                <div class="prize-desc">รองชนะเลิศอันดับ 2</div>
            </div>
        </div>

        <!-- CTA Section -->
        <div class="text-center py-5">
            <h2 class="mb-4" style="color: var(--primary-gold);">พร้อมที่จะแข่งขันแล้วหรือยัง?</h2>
            <p class="mb-4" style="color: #aaa;">สมัครเข้าร่วมการแข่งขันและคว้าเงินรางวัลกว่า 40,000 บาท!</p>
            <a href="/register" class="btn btn-custom btn-lg">
                <i class="bi bi-lightning-charge-fill me-2"></i>สมัครเข้าแข่งขันทันที
            </a>
        </div>
    </div>
</section>