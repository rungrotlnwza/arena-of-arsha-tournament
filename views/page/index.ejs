<script>
    // Load home data
    fetch('/api/home', { credentials: 'include', method: 'GET' })
        .then(res => res.json())
        .then(result => {
            if (!result.success) return;

            const data = result.data;
            const tournament = data.tournament;
            const reg = data.registration;

            // Update tournament info
            const tournamentInfo = document.getElementById('tournamentInfo');
            if (tournamentInfo) {
                tournamentInfo.textContent =
                    `${tournament.name} | ${tournament.date} | ${tournament.location}`;
            }

            const tournamentDateDisplay = document.getElementById('tournamentDateDisplay');
            if (tournamentDateDisplay) {
                tournamentDateDisplay.textContent =
                    new Date(tournament.date).toLocaleDateString('th-TH', {
                        year: 'numeric', month: 'long', day: 'numeric'
                    });
            }

            // Update info cards
            document.getElementById('infoContainer').innerHTML = `
                <div class="col-md-3 col-6 text-center">
                    <div class="p-3 rounded" style="background: rgba(255,215,0,0.1); border: 1px solid var(--primary-gold);">
                        <div class="fs-2 fw-bold" style="color: var(--primary-gold);">${reg.approved_teams}</div>
                        <small class="text-light">ทีมที่สมัคร</small>
                    </div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="p-3 rounded" style="background: rgba(255,215,0,0.1); border: 1px solid var(--primary-gold);">
                        <div class="fs-2 fw-bold" style="color: var(--primary-gold);">${reg.max_teams}</div>
                        <small class="text-light">ทีมสูงสุด</small>
                    </div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="p-3 rounded" style="background: rgba(255,215,0,0.1); border: 1px solid var(--primary-gold);">
                        <div class="fs-2 fw-bold" style="color: var(--primary-gold);">${reg.remaining}</div>
                        <small class="text-light">ที่นั่งเหลือ</small>
                    </div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="p-3 rounded" style="background: rgba(255,215,0,0.1); border: 1px solid var(--primary-gold);">
                        <div class="fs-2 fw-bold" style="color: var(--primary-gold);">${parseInt(tournament.prize_first).toLocaleString()}</div>
                        <small class="text-light">รางวัลที่ 1 (บาท)</small>
                    </div>
                </div>
            `;

            // Update registration status
            const regStatus = document.getElementById('registrationStatus');
            if (reg.open) {
                regStatus.innerHTML = `
                    <div class="mb-2"><span class="badge bg-success fs-6">เปิดรับสมัคร</span></div>
                    <div class="progress mb-2" style="height: 20px; width: 300px; margin: 0 auto;">
                        <div class="progress-bar bg-warning" style="width: ${(reg.approved_teams / reg.max_teams) * 100}%; color: #000;">
                            ${reg.approved_teams}/${reg.max_teams}
                        </div>
                    </div>
                    <small class="text-light">เหลือ ${reg.remaining} ทีม</small>
                `;
            } else {
                regStatus.innerHTML = `
                    <div class="mb-2"><span class="badge bg-secondary fs-6">ปิดรับสมัคร</span></div>
                    <p class="text-light mb-0">ขอบคุณทุกทีมที่ให้ความสนใจ</p>
                `;
                document.getElementById('registerBtn').classList.add('disabled');
                document.getElementById('registerBtn').innerHTML = '<i class="bi bi-lock-fill me-2"></i>ปิดรับสมัคร';
            }
        });
</script>

