<!-- Header -->
<div class="admin-header">
    <h4 class="mb-0" style="color: var(--primary-gold);">
        <i class="bi bi-gear me-2"></i>ตั้งค่าการแข่งขัน
    </h4>
</div>

<div class="row">
    <!-- Registration Settings -->
    <div class="col-lg-8">
        <div class="admin-card">
            <h5 class="mb-4" style="color: var(--primary-gold);">
                <i class="bi bi-clock me-2"></i>การรับสมัคร
            </h5>
            <form id="registrationForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">วันเวลาเปิดรับสมัคร</label>
                        <input type="datetime-local" class="form-control bg-dark text-light" id="registration_start">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">วันเวลาปิดรับสมัคร</label>
                        <input type="datetime-local" class="form-control bg-dark text-light" id="registration_end">
                    </div>
                </div>
                <div class="alert alert-info" style="background: rgba(13, 202, 240, 0.1); border-color: rgba(13, 202, 240, 0.3); color: #ddd;">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>อัตโนมัติ:</strong> ระบบจะเปิดรับสมัครตามเวลาที่กำหนด และปิดเมื่อหมดเวลาหรือทีมครบจำนวน
                </div>
            </form>
        </div>
        
        <div class="admin-card">
            <button type="button" class="btn btn-admin w-100" onclick="saveSettings()">
                <i class="bi bi-save me-2"></i>บันทึกการตั้งค่า
            </button>
        </div>
    </div>
    
    <!-- Quick Info -->
    <div class="col-lg-4">
        <div class="admin-card">
            <h5 class="mb-3" style="color: var(--primary-gold);">
                <i class="bi bi-info-circle me-2"></i>ข้อมูลล่าสุด
            </h5>
            <div id="currentSettings" class="text-muted">
                <p>กำลังโหลด...</p>
            </div>
        </div>
    </div>
</div>

<script>
    let currentConfig = {};
    
    // Load settings
    fetch('/api/admin/config', { credentials: 'include' })
        .then(res => {
            if (res.status === 401) {
                window.location.href = '/admin/login';
                return;
            }
            return res.json();
        })
        .then(result => {
            if (!result || !result.success) return;
            
            currentConfig = result.data;
            
            // Fill form
            document.getElementById('registration_start').value = formatDateTimeLocal(currentConfig.registration_start);
            document.getElementById('registration_end').value = formatDateTimeLocal(currentConfig.registration_end);
            
            // คำนวณสถานะรับสมัครตามเวลา
            const now = new Date();
            const regStart = currentConfig.registration_start ? new Date(currentConfig.registration_start) : null;
            const regEnd = currentConfig.registration_end ? new Date(currentConfig.registration_end) : null;
            let statusText = 'ปิด';
            let statusColor = '#888';
            
            if (regStart && now < regStart) {
                const diff = regStart - now;
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                statusText = `เร็วๆ นี้ (อีก ${days} วัน ${hours} ชม.)`;
                statusColor = 'var(--primary-gold)';
            } else if (regEnd && now > regEnd) {
                statusText = 'หมดเวลาแล้ว';
                statusColor = '#dc3545';
            } else if (regStart && regEnd && now >= regStart && now <= regEnd) {
                statusText = 'เปิดรับสมัคร';
                statusColor = '#28a745';
            }
            
            // Show current info
            document.getElementById('currentSettings').innerHTML = `
                <p><strong>สถานะ:</strong> <span style="color: ${statusColor};">${statusText}</span></p>
                <hr style="border-color: var(--border-color);">
                <p class="mb-1"><small><strong>เปิดรับสมัคร:</strong><br>${regStart ? regStart.toLocaleString('th-TH') : '-'}</small></p>
                <p class="mb-0"><small><strong>ปิดรับสมัคร:</strong><br>${regEnd ? regEnd.toLocaleString('th-TH') : '-'}</small></p>
            `;
        });
    
    function formatDateTimeLocal(dateStr) {
        if (!dateStr) return '';
        const d = new Date(dateStr);
        if (isNaN(d.getTime())) return '';
        return d.toISOString().slice(0, 16);
    }
    
    function saveSettings() {
        const data = {
            registration_start: document.getElementById('registration_start').value,
            registration_end: document.getElementById('registration_end').value
        };
        
        fetch('/api/admin/config', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(result => {
            if (result.success) {
                alert('บันทึกสำเร็จ');
                location.reload();
            } else {
                alert(result.message || 'เกิดข้อผิดพลาด');
            }
        });
    }
</script>
