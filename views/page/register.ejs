<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-person-plus-fill me-3"></i>สมัครเข้าแข่งขัน</h1>
        <p class="page-subtitle">กรอกข้อมูลทีมของคุณเพื่อเข้าร่วมการแข่งขัน Arena of Arsha</p>
    </div>
</header>

<!-- Steps Indicator -->
<div class="container mb-4">
    <div class="steps-indicator d-flex justify-content-center">
        <div class="step text-center px-4 active">
            <div class="step-number d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 50px; height: 50px; border-radius: 50%; background: var(--primary-gold); color: #000; font-weight: 700;">1</div>
            <div style="color: var(--primary-gold); font-size: 0.9rem;">กรอกข้อมูล</div>
        </div>
        <div class="step text-center px-4">
            <div class="step-number d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 50px; height: 50px; border-radius: 50%; background: rgba(255,215,0,0.2); border: 2px solid var(--primary-gold); color: var(--primary-gold); font-weight: 700;">2</div>
            <div style="color: #888; font-size: 0.9rem;">ตรวจสอบ</div>
        </div>
        <div class="step text-center px-4">
            <div class="step-number d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 50px; height: 50px; border-radius: 50%; background: rgba(255,215,0,0.2); border: 2px solid var(--primary-gold); color: var(--primary-gold); font-weight: 700;">3</div>
            <div style="color: #888; font-size: 0.9rem;">ยืนยัน</div>
        </div>
    </div>
</div>

<!-- Form Container -->
<div class="form-container mb-5" style="max-width: 800px; margin: 0 auto; padding: 0 20px;">
    <div class="form-card">
        <!-- Info Box -->
        <div class="info-box mb-4">
            <h5><i class="bi bi-info-circle-fill me-2"></i>ก่อนสมัคร โปรดอ่าน</h5>
            <ul>
                <li>ทีมต้องมีผู้เล่น 2 คน (ผู้เข้าร่วมต้องหาคู่ของตนเองมา)</li>
                <li>อาชีพของผู้เข้าแข่งขันจะถูกสุ่มโดยระบบของทีมงาน (ผู้เข้าร่วมไม่สามารถเลือกอาชีพได้)</li>
                <li>วันการแข่งขัน วันที่ 00/00/0000 เวลา 00.00น.</li>
                <li>หากมีข้อสงสัยเพิ่มเติม กรุณาอ่าน <a href="/rules" style="color: var(--primary-gold);">กติกาการแข่งขัน</a></li>
            </ul>
        </div>

        <form id="registrationForm" action="/register" method="POST">
            <!-- Team Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-people-fill"></i> ข้อมูลทีม
                </h3>
                <div class="mb-4">
                    <label for="teamName" class="form-label">
                        ชื่อทีม <span class="required">*</span>
                    </label>
                    <input type="text" class="form-control" id="teamName" name="teamName" placeholder="ระบุชื่อทีมของคุณ" required>
                    <div class="form-text">ชื่อทีมต้องไม่หยาบคายและไม่ละเมิดลิขสิทธิ์</div>
                </div>
            </div>

            <!-- Player 1 Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-person-fill"></i> ข้อมูลผู้เล่น 1
                </h3>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player1Name" class="form-label">
                            ชื่อ-นามสกุล <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1Name" name="player1Name" placeholder="ชื่อ นามสกุล" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player1Discord" class="form-label">
                            Discord ID <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1Discord" name="player1Discord" placeholder="example#1234" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player1BdoName" class="form-label">
                            ชื่อตัวละครในเกม (BDO) <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1BdoName" name="player1BdoName" placeholder="ชื่อตัวละคร" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player1Family" class="form-label">
                            Family Name <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1Family" name="player1Family" placeholder="Family Name" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label for="player1Email" class="form-label">
                        อีเมล <span class="required">*</span>
                    </label>
                    <input type="email" class="form-control" id="player1Email" name="player1Email" placeholder="email@example.com" required>
                </div>
            </div>

            <!-- Player 2 Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-person-fill"></i> ข้อมูลผู้เล่น 2 (คู่ทีม)
                </h3>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player2Name" class="form-label">
                            ชื่อ-นามสกุล <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2Name" name="player2Name" placeholder="ชื่อ นามสกุล" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player2Discord" class="form-label">
                            Discord ID <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2Discord" name="player2Discord" placeholder="example#1234" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player2BdoName" class="form-label">
                            ชื่อตัวละครในเกม (BDO) <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2BdoName" name="player2BdoName" placeholder="ชื่อตัวละคร" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player2Family" class="form-label">
                            Family Name <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2Family" name="player2Family" placeholder="Family Name" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label for="player2Email" class="form-label">
                        อีเมล <span class="required">*</span>
                    </label>
                    <input type="email" class="form-control" id="player2Email" name="player2Email" placeholder="email@example.com" required>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-chat-square-text-fill"></i> ข้อมูลเพิ่มเติม
                </h3>
                <div class="mb-4">
                    <label for="teamExperience" class="form-label">ประสบการณ์การแข่งขัน (ถ้ามี)</label>
                    <textarea class="form-control" id="teamExperience" name="teamExperience" rows="3" placeholder="เล่าประสบการณ์การแข่งขันหรือความเชี่ยวชาญของทีมคุณ"></textarea>
                </div>
                <div class="mb-4">
                    <label for="referral" class="form-label">รู้จักการแข่งขันนี้จากช่องทางใด</label>
                    <select class="form-select" id="referral" name="referral">
                        <option value="" selected>เลือกช่องทาง</option>
                        <option value="facebook">Facebook</option>
                        <option value="discord">Discord</option>
                        <option value="twitch">Twitch</option>
                        <option value="friend">เพื่อนแนะนำ</option>
                        <option value="other">อื่นๆ</option>
                    </select>
                </div>
            </div>

            <!-- Agreement -->
            <div class="mb-5">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="agreeRules" name="agreeRules" required>
                    <label class="form-check-label" for="agreeRules" style="color: #ccc;">
                        ข้าพเจ้าได้อ่านและยอมรับ <a href="/rules" style="color: var(--primary-gold);">กติกาการแข่งขัน</a> ทุกประการ <span class="required">*</span>
                    </label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="agreeData" name="agreeData" required>
                    <label class="form-check-label" for="agreeData" style="color: #ccc;">
                        ยินยอมให้เก็บข้อมูลส่วนตัวเพื่อใช้ในการติดต่อเกี่ยวกับการแข่งขัน <span class="required">*</span>
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="agreeLive" name="agreeLive">
                    <label class="form-check-label" for="agreeLive" style="color: #ccc;">
                        ยินยอมให้ถ่ายทอดสดและเผยแพร่การแข่งขัน (การตอบคำถามนี้ไม่มีผลต่อการคัดเลือก)
                    </label>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-custom w-100" style="padding: 18px; font-size: 1.2rem; font-weight: 700;">
                <i class="bi bi-send-fill me-2"></i> ยืนยันการสมัคร
            </button>
        </form>
    </div>
</div>

<script>
    document.getElementById('registrationForm').addEventListener('submit', function (e) {
        // Form validation and submission will be handled by the server
        console.log('Form submitted');
    });
</script>