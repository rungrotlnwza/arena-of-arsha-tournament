<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-person-plus-fill me-3"></i>สมัครเข้าแข่งขัน</h1>
        <p class="page-subtitle" id="tournamentSubtitle">กรอกข้อมูลทีมของคุณ</p>
    </div>
</header>

<!-- Loading State -->
<div id="loadingState" class="container py-5 text-center">
    <div class="spinner-border text-warning" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<!-- Closed State -->
<div id="closedState" class="container py-5" style="display: none;">
    <div class="text-center py-5" style="background: rgba(30,30,30,0.9); border-radius: 15px; border: 1px solid #444;">
        <i class="bi bi-lock-fill fs-1 mb-3 d-block" style="color: #888;"></i>
        <h3 style="color: #ccc;">ปิดรับสมัครแล้ว</h3>
        <p style="color: #888;">ขออภัย หมดเวลารับสมัครเข้าร่วมการแข่งขัน</p>
        <a href="/" class="btn btn-outline-custom mt-3">
            <i class="bi bi-arrow-left me-2"></i>กลับหน้าหลัก
        </a>
    </div>
</div>

<!-- Form Container -->
<div id="formContainer" class="form-container mb-5" style="max-width: 800px; margin: 0 auto; padding: 0 20px; display: none;">
    <div class="form-card">
        <!-- Tournament Info -->
        <div id="tournamentInfo" class="mb-4 p-3" style="background: rgba(255,215,0,0.1); border: 1px solid var(--primary-gold); border-radius: 10px;">
            <h5 style="color: var(--primary-gold); margin-bottom: 10px;">
                <i class="bi bi-trophy-fill me-2"></i><span id="tournamentName">Arena of Arsha Tournament 2026</span>
            </h5>
            <div class="row">
                <div class="col-md-6">
                    <small style="color: #aaa;"><i class="bi bi-calendar3 me-1"></i><span id="tournamentDate">-</span></small>
                </div>
                <div class="col-md-6">
                    <small style="color: #aaa;"><i class="bi bi-geo-alt me-1"></i><span id="tournamentLocation">Online</span></small>
                </div>
            </div>
        </div>

        <div id="capacityNotice" class="mb-4 p-3" style="display: none; border-radius: 10px;"></div>

        <!-- Info Box -->
        <div class="info-box mb-4">
            <h5><i class="bi bi-info-circle-fill me-2"></i>ก่อนสมัคร โปรดอ่าน</h5>
            <ul>
                <li>ทีมต้องมีผู้เล่น 2 คน (ผู้เข้าร่วมต้องหาคู่ของตนเองมา)</li>
                <li>อาชีพของผู้เข้าแข่งขันจะถูกสุ่มโดยระบบของทีมงาน (ผู้เข้าร่วมไม่สามารถเลือกอาชีพได้)</li>
                <li>หากมีข้อสงสัยเพิ่มเติม กรุณาอ่าน <a href="/rules" style="color: var(--primary-gold);">กติกาการแข่งขัน</a></li>
            </ul>
        </div>

        <form id="registrationForm">
            <!-- Team Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-people-fill"></i> ข้อมูลทีม
                </h3>
                <div class="mb-4">
                    <label for="teamName" class="form-label">
                        ชื่อทีม <span class="required">*</span>
                    </label>
                    <input type="text" class="form-control" id="teamName" placeholder="ระบุชื่อทีมของคุณ" required>
                    <div class="form-text">ชื่อทีมต้องไม่หยาบคาย</div>
                </div>
            </div>

            <!-- Player 1 Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-person-fill"></i> ข้อมูลผู้เล่น 1
                </h3>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player1Family" class="form-label">
                            ชื่อตระกูล <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1Family" placeholder="ชื่อตระกูล" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player1Discord" class="form-label">
                            Discord ID <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player1Discord" placeholder="example" required>
                        <div class="form-text">ไอดี Discord ไม่รวม # และตัวเลข</div>
                    </div>
                </div>
            </div>

            <!-- Player 2 Information -->
            <div class="mb-5">
                <h3 class="form-section-title">
                    <i class="bi bi-person-fill"></i> ข้อมูลผู้เล่น 2 (คู่ทีม)
                </h3>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="player2Family" class="form-label">
                            ชื่อตระกูล <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2Family" placeholder="ชื่อตระกูล" required>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="player2Discord" class="form-label">
                            Discord ID <span class="required">*</span>
                        </label>
                        <input type="text" class="form-control" id="player2Discord" placeholder="example" required>
                        <div class="form-text">ไอดี Discord ไม่รวม # และตัวเลข</div>
                    </div>
                </div>
            </div>

            <!-- Agreement -->
            <div class="mb-5">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="agreeDiscord">
                    <label class="form-check-label" for="agreeDiscord" style="color: #ccc;">
                        ฉันได้เข้าร่วม Discord AOATHEALLRANDOM แล้ว <a href="https://discord.gg/Zxjj8FCRe9" target="_blank" style="color: var(--primary-gold);">Discord</a>
                    </label>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="agreeRules" required>
                    <label class="form-check-label" for="agreeRules" style="color: #ccc;">
                        ฉันได้อ่านและยอมรับ <a href="/rules" style="color: var(--primary-gold);">กติกาการแข่งขัน</a> ทุกประการ <span class="required">*</span>
                    </label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="agreeLive">
                    <label class="form-check-label" for="agreeLive" style="color: #ccc;">
                        ฉันให้ถ่ายทอดสดและเผยแพร่การแข่งขัน
                    </label>
                </div>

            </div>

            <!-- Error Message -->
            <div id="errorMessage" class="alert alert-danger mb-4" style="display: none;"></div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-custom w-100" id="submitBtn" style="padding: 18px; font-size: 1.2rem; font-weight: 700;">
                <i class="bi bi-send-fill me-2"></i> ยืนยันการสมัคร
            </button>
        </form>
    </div>
</div>

<script>
    // Load config
    fetch('/api/config', { credentials: 'include', method: 'GET' })
        .then(res => res.json())
        .then(result => {
            document.getElementById('loadingState').style.display = 'none';

            if (!result.success) {
                showClosedState();
                return;
            }

            const config = result.data;

            // Check if registration is open
            if (config.registration_open === 'false') {
                showClosedState();
                return;
            }

            // Show form
            document.getElementById('formContainer').style.display = 'block';

            // Fill tournament info
            document.getElementById('tournamentName').textContent = config.tournament_name || 'Arena of Arsha Tournament 2026';
            const dateStr = config.tournament_date ? new Date(config.tournament_date).toLocaleDateString('th-TH') : '-';
            const timeStr = config.tournament_time || '';
            document.getElementById('tournamentDate').textContent = dateStr + (timeStr ? ' ' + timeStr : '');
            document.getElementById('tournamentLocation').textContent = config.location || 'Online';
            updateCapacityNotice(config);
        }, () => {
            document.getElementById('loadingState').style.display = 'none';
            showClosedState();
        });

    function showClosedState() {
        document.getElementById('closedState').style.display = 'block';
    }

    function updateCapacityNotice(config) {
        const capacityNotice = document.getElementById('capacityNotice');
        const maxTeams = parseInt(config.max_teams || '32', 10);
        const activeTeams = parseInt(config.active_teams || '0', 10);
        const nextReservePosition = parseInt(config.next_reserve_position || '0', 10);

        if (activeTeams >= maxTeams && nextReservePosition > 0) {
            capacityNotice.style.display = 'block';
            capacityNotice.style.background = 'rgba(255, 193, 7, 0.12)';
            capacityNotice.style.border = '1px solid rgba(255, 193, 7, 0.45)';
            capacityNotice.innerHTML = `
                <h5 style="color: #ffd761; margin-bottom: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>ทีมหลักครบแล้ว
                </h5>
                <p style="color: #ddd; margin-bottom: 0;">
                    หากสมัครตอนนี้ ทีมของคุณจะถูกจัดเป็นทีมสำรองลำดับที่ <strong>${nextReservePosition}</strong>
                </p>
            `;
        }
    }

    // Form submission
    document.getElementById('registrationForm').addEventListener('submit', function (e) {
        e.preventDefault();

        const errorDiv = document.getElementById('errorMessage');
        const submitBtn = document.getElementById('submitBtn');

        errorDiv.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>กำลังสมัคร...';

        const data = {
            team_name: document.getElementById('teamName').value.trim(),
            players: [
                {
                    family_name: document.getElementById('player1Family').value.trim(),
                    discord_id: document.getElementById('player1Discord').value.trim()
                },
                {
                    family_name: document.getElementById('player2Family').value.trim(),
                    discord_id: document.getElementById('player2Discord').value.trim()
                }
            ],
            agree_live: document.getElementById('agreeLive').checked,
            agree_discord: document.getElementById('agreeDiscord').checked
        };

        fetch('/api/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    let successUrl = '/register-success?team=' + encodeURIComponent(result.data.team_name || data.team_name);

                    if (result.data && result.data.reserve_position) {
                        successUrl += '&reserve=' + encodeURIComponent(result.data.reserve_position);
                    }

                    window.location.href = successUrl;
                } else {
                    errorDiv.textContent = result.message || 'เกิดข้อผิดพลาด';
                    errorDiv.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-send-fill me-2"></i> ยืนยันการสมัคร';
                }
            }, () => {
                errorDiv.textContent = 'เกิดข้อผิดพลาดในการเชื่อมต่อ';
                errorDiv.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-send-fill me-2"></i> ยืนยันการสมัคร';
            });
    });
</script>