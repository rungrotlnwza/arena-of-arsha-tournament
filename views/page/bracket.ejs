<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-diagram-3 me-3"></i>ตารางการแข่งขัน</h1>
        <p class="page-subtitle">Arena of Arsha Tournament 2026 - Tournament Bracket</p>
    </div>
</header>

<div class="bracket-wrapper">
    <div id="bracketContainer" class="bracket-state">
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
        </div>
    </div>
</div>

<script>
    const preferredRounds = ['round_1', 'round_2', 'quarter', 'semi', 'final'];
    const roundLabels = {
        round_1: 'รอบแรก',
        round_2: 'รอบถัดไป',
        quarter: 'รอบ 8 ทีม',
        semi: 'รอบ 4 ทีมสุดท้าย',
        final: 'รอบชิงชนะเลิศ'
    };
    const boardConfig = {
        headerHeight: 94,
        cardWidth: 320,
        cardHeight: 176,
        columnGap: 120,
        rowGap: 28,
        paddingLeft: 8,
        paddingRight: 24,
        paddingBottom: 24
    };

    enableGrabScroll(document.querySelector('.bracket-wrapper'));

    fetch('/api/bracket', { credentials: 'include', method: 'GET' })
        .then(res => res.json())
        .then(result => {
            if (!result.success) {
                renderState('error');
                return;
            }

            const data = result.data;
            const rounds = buildRoundStructure(data || {}, result.meta?.initial_round_1_match_count || 0);
            if (rounds.length) {
                renderBracket(rounds);
            } else {
                renderState('empty');
            }
        }, () => {
            renderState('error');
        });

    function buildRoundStructure(roundsData, fallbackFirstRoundMatchCount) {
        const grouped = {};

        preferredRounds.forEach(key => {
            if (Array.isArray(roundsData[key]) && roundsData[key].length) {
                grouped[key] = roundsData[key].slice().sort((left, right) => (left.match_number || 0) - (right.match_number || 0));
            }
        });

        Object.keys(roundsData)
            .filter(key => !preferredRounds.includes(key) && Array.isArray(roundsData[key]) && roundsData[key].length)
            .sort((left, right) => getRoundSortValue(left) - getRoundSortValue(right))
            .forEach(key => {
                grouped[key] = roundsData[key].slice().sort((left, right) => (left.match_number || 0) - (right.match_number || 0));
            });

        if (grouped.round_1 && grouped.round_1.length) {
            return buildRoundSequence(grouped.round_1.length).map(round => {
                return buildRoundDisplay(round, grouped[round.key] || []);
            });
        }

        const orderedRoundKeys = getOrderedRoundKeys(grouped);

        if (orderedRoundKeys.length) {
            return orderedRoundKeys.map(roundKey => {
                return buildRoundDisplay({
                    key: roundKey,
                    matchCount: grouped[roundKey].length
                }, grouped[roundKey]);
            });
        }

        if (fallbackFirstRoundMatchCount) {
            return buildRoundSequence(fallbackFirstRoundMatchCount).map(round => {
                return buildRoundDisplay(round, []);
            });
        }

        return [];
    }

    function getOrderedRoundKeys(grouped) {
        const preferred = preferredRounds.filter(key => Array.isArray(grouped[key]) && grouped[key].length);
        const extra = Object.keys(grouped)
            .filter(key => !preferredRounds.includes(key) && Array.isArray(grouped[key]) && grouped[key].length)
            .sort((left, right) => getRoundSortValue(left) - getRoundSortValue(right));

        return preferred.concat(extra);
    }

    function buildRoundDisplay(roundDefinition, matches) {
        const actualMatchCount = matches.length;
        const matchCount = getDisplayMatchCount(roundDefinition.key, roundDefinition.matchCount, actualMatchCount);

        return {
            key: roundDefinition.key,
            label: getRoundLabel(roundDefinition.key, matchCount),
            note: getRoundNote(roundDefinition.key, matchCount),
            matchCount: matchCount,
            displayMode: getRoundDisplayMode(roundDefinition.key, roundDefinition.displayMode, matchCount, actualMatchCount),
            slots: fillMatchSlots(matches, matchCount)
        };
    }

    function buildRoundSequence(firstRoundMatchCount) {
        const rounds = [{
            key: 'round_1',
            matchCount: firstRoundMatchCount,
            displayMode: 'bracket'
        }];

        let currentRoundNumber = 1;
        let currentMatchCount = firstRoundMatchCount;

        while (currentMatchCount > 1) {
            if (currentMatchCount === 4) {
                rounds.push({
                    key: 'semi',
                    matchCount: 6,
                    displayMode: 'stacked'
                });
                rounds.push({
                    key: 'final',
                    matchCount: 2,
                    displayMode: 'stacked'
                });
                break;
            }

            const nextMatchCount = Math.ceil(currentMatchCount / 2);
            let nextRoundKey = 'final';

            if (nextMatchCount === 4) {
                nextRoundKey = 'quarter';
            } else if (nextMatchCount === 2) {
                nextRoundKey = 'semi';
            } else if (nextMatchCount > 1) {
                currentRoundNumber += 1;
                nextRoundKey = `round_${currentRoundNumber}`;
            }

            rounds.push({
                key: nextRoundKey,
                matchCount: nextMatchCount,
                displayMode: 'bracket'
            });

            currentMatchCount = nextMatchCount;
        }

        return rounds;
    }

    function getDisplayMatchCount(roundKey, expectedMatchCount, actualMatchCount) {
        if (roundKey === 'semi') {
            return Math.max(expectedMatchCount, actualMatchCount, 6);
        }

        if (roundKey === 'final' && expectedMatchCount > 1) {
            return Math.max(expectedMatchCount, actualMatchCount, 2);
        }

        return Math.max(expectedMatchCount, actualMatchCount);
    }

    function getRoundDisplayMode(roundKey, preferredDisplayMode, matchCount, actualMatchCount) {
        if (preferredDisplayMode) {
            return preferredDisplayMode;
        }

        if (roundKey === 'semi' && Math.max(matchCount, actualMatchCount) > 2) {
            return 'stacked';
        }

        if (roundKey === 'final' && Math.max(matchCount, actualMatchCount) > 1) {
            return 'stacked';
        }

        return 'bracket';
    }

    function getRoundNote(roundKey, matchCount) {
        if (roundKey === 'semi') {
            return 'พบกันหมด นับคะแนนรวมเพื่อจัดอันดับ';
        }

        if (roundKey === 'final' && matchCount > 1) {
            return 'ชิงอันดับ 3 และชิงชนะเลิศ';
        }

        return '';
    }

    function fillMatchSlots(matches, expectedCount) {
        const slots = new Array(expectedCount).fill(null);

        matches.forEach(match => {
            const slotIndex = Math.max((match.match_number || 1) - 1, 0);

            if (slotIndex < slots.length) {
                slots[slotIndex] = match;
            }
        });

        return slots.map((match, index) => ({
            match: match,
            matchNumber: index + 1
        }));
    }

    function buildBoardLayout(rounds) {
        const centers = [];
        const columns = [];
        const columnHeights = rounds.map(round => getColumnContentHeight(round.slots.length));
        const maxColumnHeight = Math.max(...columnHeights, 0);

        for (let roundIndex = 0; roundIndex < rounds.length; roundIndex++) {
            columns[roundIndex] = boardConfig.paddingLeft + roundIndex * (boardConfig.cardWidth + boardConfig.columnGap);
        }

        centers[0] = buildTopAlignedCenters(rounds[0].slots.length);

        for (let roundIndex = 1; roundIndex < rounds.length; roundIndex++) {
            if (rounds[roundIndex].displayMode !== 'bracket' || rounds[roundIndex - 1].displayMode !== 'bracket') {
                centers[roundIndex] = buildCenteredCenters(rounds[roundIndex].slots.length, maxColumnHeight);
                continue;
            }

            centers[roundIndex] = [];

            for (let slotIndex = 0; slotIndex < rounds[roundIndex].slots.length; slotIndex++) {
                const topChild = centers[roundIndex - 1][slotIndex * 2];
                const bottomChild = centers[roundIndex - 1][slotIndex * 2 + 1];

                if (typeof topChild === 'number' && typeof bottomChild === 'number') {
                    centers[roundIndex][slotIndex] = (topChild + bottomChild) / 2;
                } else if (typeof topChild === 'number') {
                    centers[roundIndex][slotIndex] = topChild;
                } else if (typeof bottomChild === 'number') {
                    centers[roundIndex][slotIndex] = bottomChild;
                } else {
                    centers[roundIndex][slotIndex] = boardConfig.headerHeight + (boardConfig.cardHeight / 2);
                }
            }
        }

        const bottomEdges = centers.map(roundCenters => {
            if (!roundCenters.length) {
                return boardConfig.headerHeight;
            }

            return roundCenters[roundCenters.length - 1] + (boardConfig.cardHeight / 2);
        });

        return {
            width: columns[columns.length - 1] + boardConfig.cardWidth + boardConfig.paddingRight,
            height: Math.max(...bottomEdges, boardConfig.headerHeight) + boardConfig.paddingBottom,
            columns: columns,
            centers: centers
        };
    }

    function getColumnContentHeight(slotCount) {
        if (!slotCount) {
            return 0;
        }

        return (slotCount * boardConfig.cardHeight) + (Math.max(slotCount - 1, 0) * boardConfig.rowGap);
    }

    function buildTopAlignedCenters(slotCount) {
        const centers = [];

        for (let slotIndex = 0; slotIndex < slotCount; slotIndex++) {
            centers[slotIndex] = boardConfig.headerHeight + (boardConfig.cardHeight / 2) + (slotIndex * (boardConfig.cardHeight + boardConfig.rowGap));
        }

        return centers;
    }

    function buildCenteredCenters(slotCount, availableHeight) {
        const centers = [];
        const columnHeight = getColumnContentHeight(slotCount);
        const topOffset = boardConfig.headerHeight + Math.max((availableHeight - columnHeight) / 2, 0);

        for (let slotIndex = 0; slotIndex < slotCount; slotIndex++) {
            centers[slotIndex] = topOffset + (boardConfig.cardHeight / 2) + (slotIndex * (boardConfig.cardHeight + boardConfig.rowGap));
        }

        return centers;
    }

    function createConnectorPaths(rounds, layout) {
        let paths = '';

        for (let roundIndex = 0; roundIndex < rounds.length - 1; roundIndex++) {
            if (rounds[roundIndex].displayMode !== 'bracket' || rounds[roundIndex + 1].displayMode !== 'bracket') {
                continue;
            }

            for (let slotIndex = 0; slotIndex < rounds[roundIndex].slots.length; slotIndex++) {
                const currentCenterY = layout.centers[roundIndex][slotIndex];
                const nextCenterY = layout.centers[roundIndex + 1][Math.floor(slotIndex / 2)];

                if (typeof currentCenterY !== 'number' || typeof nextCenterY !== 'number') {
                    continue;
                }

                const x1 = layout.columns[roundIndex] + boardConfig.cardWidth;
                const x2 = layout.columns[roundIndex + 1];
                const midX = x1 + ((x2 - x1) / 2);

                paths += `
                    <path d="M ${x1} ${currentCenterY} L ${midX} ${currentCenterY} L ${midX} ${nextCenterY} L ${x2} ${nextCenterY}" />
                `;
            }
        }

        return paths;
    }

    function renderState(type) {
        const container = document.getElementById('bracketContainer');

        if (type === 'empty') {
            container.innerHTML = `
                <div class="state-card">
                    <i class="bi bi-calendar-x state-icon"></i>
                    <h4>ยังไม่มีตารางการแข่งขัน</h4>
                    <p>รอการประกาศคู่แข่งขันจากทางผู้จัดการแข่งขัน</p>
                </div>
            `;
            return;
        }

        container.innerHTML = `
            <div class="state-card">
                <i class="bi bi-exclamation-circle state-icon is-error"></i>
                <h4>เกิดข้อผิดพลาด</h4>
                <p>ไม่สามารถโหลดตารางการแข่งขันได้</p>
            </div>
        `;
    }

    function renderBracket(rounds) {
        const container = document.getElementById('bracketContainer');
        const layout = buildBoardLayout(rounds);
        let html = `
            <div class="bracket-board" style="width: ${layout.width}px; height: ${layout.height}px;">
                <svg class="connector-layer" viewBox="0 0 ${layout.width} ${layout.height}" preserveAspectRatio="none">
                    ${createConnectorPaths(rounds, layout)}
                </svg>
        `;

        rounds.forEach((round, roundIndex) => {
            html += `
                <div class="round-heading" style="left: ${layout.columns[roundIndex]}px; width: ${boardConfig.cardWidth}px;">
                    <span class="round-chip">${escapeHtml(round.label)}</span>
                    <p class="round-count">${escapeHtml(getRoundCountText(round.key, round.matchCount))}</p>
                    ${round.note ? `<p class="round-note">${escapeHtml(round.note)}</p>` : ''}
                </div>
            `;

            round.slots.forEach((slot, slotIndex) => {
                html += createMatchCard(round, slot, layout.columns[roundIndex], layout.centers[roundIndex][slotIndex], roundIndex);
            });
        });

        html += '</div>';
        container.innerHTML = html;
    }

    function enableGrabScroll(viewport) {
        if (!viewport) {
            return;
        }

        const dragState = {
            isPointerDown: false,
            isDragging: false,
            startX: 0,
            startY: 0,
            startScrollLeft: 0,
            startScrollTop: 0,
            startPageScrollTop: 0
        };
        const interactiveSelector = 'a, button, input, select, textarea, label, summary, [role="button"]';

        viewport.addEventListener('mousedown', event => {
            if (event.button !== 0 || event.target.closest(interactiveSelector)) {
                return;
            }

            dragState.isPointerDown = true;
            dragState.isDragging = false;
            dragState.startX = event.clientX;
            dragState.startY = event.clientY;
            dragState.startScrollLeft = viewport.scrollLeft;
            dragState.startScrollTop = viewport.scrollTop;
            dragState.startPageScrollTop = window.scrollY;
            viewport.classList.add('is-grab-ready');
        });

        window.addEventListener('mousemove', event => {
            if (!dragState.isPointerDown) {
                return;
            }

            const deltaX = event.clientX - dragState.startX;
            const deltaY = event.clientY - dragState.startY;

            if (!dragState.isDragging && Math.abs(deltaX) + Math.abs(deltaY) < 6) {
                return;
            }

            dragState.isDragging = true;
            viewport.classList.add('is-grabbing');
            document.body.classList.add('is-bracket-dragging');
            viewport.scrollLeft = dragState.startScrollLeft - deltaX;

            if (viewport.scrollHeight > viewport.clientHeight) {
                viewport.scrollTop = dragState.startScrollTop - deltaY;
            } else {
                window.scrollTo(window.scrollX, dragState.startPageScrollTop - deltaY);
            }

            event.preventDefault();
        });

        window.addEventListener('mouseup', () => {
            if (!dragState.isPointerDown) {
                return;
            }

            dragState.isPointerDown = false;
            dragState.isDragging = false;
            viewport.classList.remove('is-grab-ready', 'is-grabbing');
            document.body.classList.remove('is-bracket-dragging');
        });

        viewport.addEventListener('dragstart', event => {
            if (dragState.isPointerDown) {
                event.preventDefault();
            }
        });
    }

    function createMatchCard(round, slot, left, centerY, roundIndex) {
        const top = centerY - (boardConfig.cardHeight / 2);
        const emptyMessage = getEmptyMessage(round.key, roundIndex);
        const matchLabel = getMatchLabel(round.key, slot.matchNumber, round.matchCount);

        if (!slot.match) {
            return `
                <article class="match-card is-placeholder" style="left: ${left}px; top: ${top}px;">
                    <div class="match-header">
                        <span class="match-number">${escapeHtml(matchLabel)}</span>
                        <span class="match-status pending">รอแข่ง</span>
                    </div>
                    <div class="match-body">
                        <div class="team-row is-tbd">
                            <span>TBD</span>
                        </div>
                        <div class="team-row is-tbd">
                            <span>TBD</span>
                        </div>
                    </div>
                    <div class="match-meta is-empty">${emptyMessage}</div>
                </article>
            `;
        }

        const match = slot.match;
        const statusKey = getStatusKey(match.status);
        const isWinner1 = match.winner_id && match.winner_id === match.team1_id;
        const isWinner2 = match.winner_id && match.winner_id === match.team2_id;
        const meta = [];

        if (match.team1_score !== null || match.team2_score !== null) {
            meta.push(`
                <span class="match-meta-item is-highlight">
                    <i class="bi bi-bar-chart-line me-1"></i>คะแนน ${escapeHtml(formatScoreValue(match.team1_score))} - ${escapeHtml(formatScoreValue(match.team2_score))}
                </span>
            `);
        }

        if (match.match_time) {
            meta.push(`
                <span class="match-meta-item">
                    <i class="bi bi-clock me-1"></i>${escapeHtml(formatMatchTime(match.match_time))}
                </span>
            `);
        }

        if (match.stream_url) {
            meta.push(`
                <a class="match-meta-link" href="${escapeAttribute(match.stream_url)}" target="_blank" rel="noopener noreferrer">
                    <i class="bi bi-broadcast me-1"></i>ดูสตรีม
                </a>
            `);
        }

        return `
            <article class="match-card" style="left: ${left}px; top: ${top}px;">
                <div class="match-header">
                    <span class="match-number">${escapeHtml(matchLabel)}</span>
                    <span class="match-status ${statusKey}">${getStatusText(statusKey)}</span>
                </div>
                <div class="match-body">
                    <div class="team-row ${isWinner1 ? 'is-winner' : ''} ${!match.team1_id ? 'is-tbd' : ''}">
                        <span>${escapeHtml(match.team1_name || 'TBD')}</span>
                        ${isWinner1 ? '<i class="bi bi-trophy-fill"></i>' : ''}
                    </div>
                    <div class="team-row ${isWinner2 ? 'is-winner' : ''} ${!match.team2_id ? 'is-tbd' : ''}">
                        <span>${escapeHtml(match.team2_name || 'TBD')}</span>
                        ${isWinner2 ? '<i class="bi bi-trophy-fill"></i>' : ''}
                    </div>
                </div>
                <div class="match-meta ${meta.length ? '' : 'is-empty'}">
                    ${meta.length ? meta.join('') : 'รอข้อมูลเพิ่มเติม'}
                </div>
            </article>
        `;
    }

    function getRoundCountText(roundKey, matchCount) {
        if (roundKey === 'semi') {
            return `${matchCount} คู่รอบพบกันหมด`;
        }

        if (roundKey === 'final' && matchCount > 1) {
            return `${matchCount} คู่ตัดสินอันดับ`;
        }

        return `${matchCount} คู่แข่งขัน`;
    }

    function getMatchLabel(roundKey, matchNumber, matchCount) {
        if (roundKey === 'semi') {
            return `แมตช์สะสมคะแนน ${matchNumber}`;
        }

        if (roundKey === 'final' && matchCount > 1) {
            if (matchNumber === 1) {
                return 'ชิงอันดับที่ 3';
            }

            if (matchNumber === 2) {
                return 'ชิงชนะเลิศ';
            }
        }

        return `คู่ที่ ${matchNumber}`;
    }

    function getEmptyMessage(roundKey, roundIndex) {
        if (roundKey === 'semi') {
            return 'รอโปรแกรมแข่งรอบ 4 ทีมสุดท้าย';
        }

        if (roundKey === 'final') {
            return 'รอสรุปอันดับเพื่อจัดคู่รอบชิง';
        }

        return roundIndex === 0 ? 'ยังไม่มีการจับคู่' : 'รอผลจากรอบก่อนหน้า';
    }

    function getRoundLabel(roundKey, matchCount) {
        return roundLabels[roundKey] || `รอบ ${matchCount * 2} ทีม`;
    }

    function getRoundSortValue(round) {
        if (!round) {
            return 9999;
        }

        if (round.indexOf('round_') === 0) {
            const parsedRound = parseInt(round.split('_')[1], 10);
            return Number.isNaN(parsedRound) ? 999 : parsedRound;
        }

        if (round === 'quarter') {
            return 1000;
        }

        if (round === 'semi') {
            return 1001;
        }

        if (round === 'final') {
            return 1002;
        }

        return 9000;
    }

    function getStatusKey(status) {
        if (status === 'ongoing' || status === 'completed') {
            return status;
        }

        return 'pending';
    }

    function getStatusText(status) {
        const map = {
            pending: 'รอแข่ง',
            ongoing: 'กำลังแข่ง',
            completed: 'จบแล้ว'
        };

        return map[status] || 'รอแข่ง';
    }

    function formatMatchTime(value) {
        return new Date(value).toLocaleString('th-TH', {
            day: 'numeric',
            month: 'short',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function formatScoreValue(value) {
        if (value === null || value === undefined || value === '') {
            return '-';
        }

        return String(value);
    }

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function escapeAttribute(value) {
        return escapeHtml(value).replace(/`/g, '&#96;');
    }

</script>

<style>
    .bracket-wrapper {
        padding: 32px 20px 56px;
        overflow-x: auto;
        cursor: grab;
    }

    .bracket-state {
        min-height: 320px;
    }

    .bracket-wrapper.is-grab-ready,
    .bracket-wrapper.is-grabbing {
        cursor: grabbing;
    }

    body.is-bracket-dragging,
    body.is-bracket-dragging * {
        user-select: none;
        cursor: grabbing !important;
    }

    .bracket-board {
        position: relative;
        min-width: max-content;
    }

    .connector-layer {
        position: absolute;
        inset: 0;
        overflow: visible;
        pointer-events: none;
        z-index: 1;
    }

    .connector-layer path {
        fill: none;
        stroke: rgba(255, 215, 0, 0.72);
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
        filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.2));
    }

    .round-heading {
        position: absolute;
        top: 0;
        padding: 18px 20px;
        border: 1px solid rgba(255, 215, 0, 0.24);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(255, 215, 0, 0.12), rgba(20, 18, 10, 0.86));
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
        z-index: 3;
    }

    .round-chip {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 999px;
        background: rgba(255, 215, 0, 0.16);
        color: #ffd761;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .round-count {
        margin: 12px 0 0;
        color: rgba(255, 255, 255, 0.72);
        font-size: 14px;
    }

    .round-note {
        margin: 8px 0 0;
        color: rgba(255, 215, 97, 0.82);
        font-size: 12px;
    }

    .match-card {
        position: absolute;
        width: 320px;
        height: 176px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid rgba(255, 215, 0, 0.18);
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(37, 36, 46, 0.96), rgba(22, 22, 28, 0.96));
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.28);
        z-index: 2;
    }

    .match-card.is-placeholder {
        border-style: dashed;
    }

    .match-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 215, 0, 0.06);
    }

    .match-number {
        color: rgba(255, 255, 255, 0.72);
        font-size: 13px;
        font-weight: 600;
    }

    .match-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 72px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 11px;
