<!-- Page Header -->
<header class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-diagram-3 me-3"></i>ตารางการแข่งขัน</h1>
        <p class="page-subtitle">Arena of Arsha Tournament 2026</p>
    </div>
</header>

<!-- Bracket Container -->
<div class="container py-4">
    <!-- Round 1: Knockout Stage -->
    <section class="mb-5" id="knockoutStage">
        <h4 class="text-center mb-4" style="color: var(--primary-gold);">
            <i class="bi bi-trophy me-2"></i>รอบคัดเลือก (Best of 3)
        </h4>
        <div id="knockoutBracket" class="bracket-scroll">
            <div class="text-center py-5">
                <div class="spinner-border text-warning" role="status"></div>
            </div>
        </div>
    </section>

    <!-- Round 2: 4 Teams Round Robin -->
    <section class="mb-5" id="roundRobinStage" style="display: none;">
        <h4 class="text-center mb-4" style="color: var(--primary-gold);">
            <i class="bi bi-table me-2"></i>รอบ 4 ทีมสุดท้าย (Round Robin)
        </h4>
        
        <!-- Standings Table -->
        <div class="admin-card mb-4">
            <h5 class="mb-3" style="color: var(--primary-gold);">ตารางคะแนน</h5>
            <div class="table-responsive">
                <table class="table table-dark table-sm">
                    <thead>
                        <tr>
                            <th>อันดับ</th>
                            <th>ทีม</th>
                            <th>แข่ง</th>
                            <th>ชนะ</th>
                            <th>เสมอ</th>
                            <th>แพ้</th>
                            <th>คะแนน</th>
                        </tr>
                    </thead>
                    <tbody id="standingsTable">
                        <tr><td colspan="7" class="text-center">กำลังโหลด...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Round Robin Matches -->
        <div id="roundRobinMatches" class="row g-3">
            <!-- Matches will be loaded here -->
        </div>
    </section>

    <!-- Final Stage -->
    <section class="mb-5" id="finalStage" style="display: none;">
        <h4 class="text-center mb-4" style="color: var(--primary-gold);">
            <i class="bi bi-award me-2"></i>รอบชิงชนะเลิศ
        </h4>
        <div class="row g-4">
            <!-- 3rd Place Match -->
            <div class="col-md-6">
                <div class="admin-card h-100">
                    <h5 class="mb-3" style="color: #cd7f32;">
                        <i class="bi bi-trophy-fill me-2"></i>ชิงอันดับที่ 3 (Best of 5)
                    </h5>
                    <div id="match3rd">
                        <p class="text-muted">รอการแข่งขัน</p>
                    </div>
                </div>
            </div>
            <!-- 1st Place Match -->
            <div class="col-md-6">
                <div class="admin-card h-100" style="border: 2px solid var(--primary-gold);">
                    <h5 class="mb-3" style="color: var(--primary-gold);">
                        <i class="bi bi-trophy-fill me-2"></i>ชิงอันดับที่ 1 (Best of 9)
                    </h5>
                    <div id="match1st">
                        <p class="text-muted">รอการแข่งขัน</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
    // Load bracket data
    fetch('/api/bracket', { credentials: 'include' })
        .then(res => res.json())
        .then(result => {
            if (!result.success) {
                document.getElementById('knockoutBracket').innerHTML = `
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x fs-1 mb-3 d-block" style="color: var(--primary-gold);"></i>
                        <h4 style="color: #ccc;">ยังไม่มีตารางการแข่งขัน</h4>
                        <p class="text-muted">รอการประกาศจากทางผู้จัด</p>
                    </div>
                `;
                return;
            }

            const data = result.data;
            
            // Render Knockout Stage
            renderKnockout(data.round_1 || []);
            
            // Render Round Robin Stage if available
            if (data.round_robin && data.round_robin.length > 0) {
                document.getElementById('roundRobinStage').style.display = 'block';
                renderRoundRobin(data.round_robin, data.standings || []);
            }
            
            // Render Final Stage if available
            if (data.finals) {
                document.getElementById('finalStage').style.display = 'block';
                if (data.finals.third_place) {
                    renderFinalMatch('match3rd', data.finals.third_place, 'Best of 5');
                }
                if (data.finals.first_place) {
                    renderFinalMatch('match1st', data.finals.first_place, 'Best of 9');
                }
            }
        })
        .catch(() => {
            document.getElementById('knockoutBracket').innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-exclamation-circle fs-1 mb-3 d-block text-danger"></i>
                    <h4 style="color: #ccc;">เกิดข้อผิดพลาด</h4>
                    <p class="text-muted">ไม่สามารถโหลดตารางได้</p>
                </div>
            `;
        });

    function renderKnockout(matches) {
        const container = document.getElementById('knockoutBracket');
        
        if (matches.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x fs-1 mb-3 d-block" style="color: var(--primary-gold);"></i>
                    <h4 style="color: #ccc;">ยังไม่มีตารางรอบคัดเลือก</h4>
                </div>
            `;
            return;
        }

        // Group matches by round
        const rounds = {};
        matches.forEach(match => {
            const round = match.round || 'round_1';
            if (!rounds[round]) rounds[round] = [];
            rounds[round].push(match);
        });

        // Render rounds
        let html = '<div class="d-flex gap-4 justify-content-center flex-wrap">';
        
        Object.keys(rounds).forEach(roundKey => {
            const roundMatches = rounds[roundKey].sort((a, b) => a.match_number - b.match_number);
            html += `
                <div class="round-column">
                    <h6 class="text-center mb-3" style="color: var(--primary-gold);">${getRoundName(roundKey)}</h6>
                    <div class="d-flex flex-column gap-3">
                        ${roundMatches.map(match => createMatchCard(match)).join('')}
                    </div>
                </div>
            `;
        });
        
        html += '</div>';
        container.innerHTML = html;
    }

    function renderRoundRobin(matches, standings) {
        // Render standings
        const sortedStandings = [...standings].sort((a, b) => b.points - a.points);
        document.getElementById('standingsTable').innerHTML = sortedStandings.map((team, index) => `
            <tr>
                <td><strong style="color: ${index < 2 ? 'var(--primary-gold)' : '#ccc'};">${index + 1}</strong></td>
                <td>${escapeHtml(team.team_name)}</td>
                <td>${team.played}</td>
                <td>${team.wins}</td>
                <td>${team.draws}</td>
                <td>${team.losses}</td>
                <td><strong style="color: var(--primary-gold);">${team.points}</strong></td>
            </tr>
        `).join('');

        // Render matches
        document.getElementById('roundRobinMatches').innerHTML = matches.map(match => `
            <div class="col-md-6">
                ${createMatchCard(match)}
            </div>
        `).join('');
    }

    function renderFinalMatch(elementId, match, format) {
        document.getElementById(elementId).innerHTML = createMatchCard(match, format);
    }

    function createMatchCard(match, format = '') {
        const statusColor = {
            'pending': 'secondary',
            'ongoing': 'warning',
            'completed': 'success'
        }[match.status] || 'secondary';

        const statusText = {
            'pending': 'รอแข่ง',
            'ongoing': 'กำลังแข่ง',
            'completed': 'จบแล้ว'
        }[match.status] || 'รอแข่ง';

        return `
            <div class="match-card" style="background: rgba(30,30,30,0.9); border: 1px solid var(--border-color); border-radius: 10px; padding: 15px;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <small style="color: #888;">คู่ที่ ${match.match_number}</small>
                    <span class="badge bg-${statusColor}">${statusText}</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <span style="color: ${match.winner_id === match.team1_id ? 'var(--primary-gold)' : '#fff'}; font-weight: ${match.winner_id === match.team1_id ? '700' : '400'};">
                        ${escapeHtml(match.team1_name || 'TBD')}
                    </span>
                    ${match.winner_id === match.team1_id ? '<i class="bi bi-check-circle-fill" style="color: var(--primary-gold);"></i>' : ''}
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span style="color: ${match.winner_id === match.team2_id ? 'var(--primary-gold)' : '#fff'}; font-weight: ${match.winner_id === match.team2_id ? '700' : '400'};">
                        ${escapeHtml(match.team2_name || 'TBD')}
                    </span>
                    ${match.winner_id === match.team2_id ? '<i class="bi bi-check-circle-fill" style="color: var(--primary-gold);"></i>' : ''}
                </div>
                ${format ? `<small style="color: #888;"><i class="bi bi-info-circle me-1"></i>${format}</small>` : ''}
                ${match.stream_url ? `<a href="${escapeHtml(match.stream_url)}" target="_blank" class="btn btn-sm btn-outline-custom mt-2 w-100"><i class="bi bi-broadcast me-1"></i>รับชมสด</a>` : ''}
            </div>
        `;
    }

    function getRoundName(roundKey) {
        const names = {
            'round_1': 'รอบ 32 ทีม',
            'round_2': 'รอบ 16 ทีม',
            'quarter': 'รอบ 8 ทีม',
            'semi': 'รอบรองชนะเลิศ',
            'final': 'รอบชิงชนะเลิศ'
        };
        return names[roundKey] || roundKey;
    }

    function escapeHtml(text) {
        if (!text) return 'TBD';
        return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
</script>

<style>
    .bracket-scroll {
        overflow-x: auto;
        padding: 20px 0;
    }
    .round-column {
        min-width: 280px;
    }
    .match-card {
        transition: transform 0.2s;
    }
    .match-card:hover {
        transform: translateY(-2px);
        border-color: var(--primary-gold) !important;
    }
</style>
