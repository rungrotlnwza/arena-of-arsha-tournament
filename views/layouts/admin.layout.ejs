<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Admin Panel
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Kanit', sans-serif;
        }

        :root {
            --primary-gold: #ffd700;
            --secondary-gold: #ffed4e;
            --dark-bg: #0a0a0a;
            --card-bg: rgba(20, 20, 30, 0.95);
            --border-color: rgba(255, 215, 0, 0.3);
        }

        body {
            background: var(--dark-bg);
            color: #fff;
            min-height: 100vh;
        }

        .admin-sidebar {
            background: rgba(10, 10, 15, 0.98);
            border-right: 1px solid var(--border-color);
            min-height: 100vh;
            position: fixed;
            width: 260px;
        }

        .admin-content {
            margin-left: 260px;
            padding: 20px;
        }

        .sidebar-brand {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
            color: var(--primary-gold);
            font-weight: 700;
            font-size: 1.2rem;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar-menu li a {
            display: block;
            padding: 15px 20px;
            color: #aaa;
            text-decoration: none;
            border-left: 3px solid transparent;
            transition: all 0.3s;
        }

        .sidebar-menu li a:hover,
        .sidebar-menu li a.active {
            background: rgba(255, 215, 0, 0.1);
            color: var(--primary-gold);
            border-left-color: var(--primary-gold);
        }

        .sidebar-menu li a i {
            margin-right: 10px;
            width: 20px;
        }

        .admin-header {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 15px 20px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .admin-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .btn-admin {
            background: linear-gradient(135deg, var(--primary-gold) 0%, var(--secondary-gold) 100%);
            color: #000;
            font-weight: 600;
            border: none;
        }

        .btn-admin:hover {
            background: linear-gradient(135deg, var(--secondary-gold) 0%, var(--primary-gold) 100%);
            color: #000;
        }

        .btn-admin-outline {
            background: transparent;
            border: 1px solid var(--primary-gold);
            color: var(--primary-gold);
        }

        .btn-admin-outline:hover {
            background: rgba(255, 215, 0, 0.1);
            color: var(--primary-gold);
        }

        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .status-pending {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
        }

        .status-approved {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
        }

        .status-rejected {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
        }

        @media (max-width: 768px) {
            .admin-sidebar {
                display: none;
            }

            .admin-content {
                margin-left: 0;
            }
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-shield-lock me-2"></i>Admin Panel
        </div>
        <ul class="sidebar-menu">
            <li>
                <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">
                    <i class="bi bi-speedometer2"></i>Dashboard
                </a>
            </li>
            <li>
                <a href="/admin/teams" class="<%= active === 'teams' ? 'active' : '' %>">
                    <i class="bi bi-people"></i>จัดการทีม
                </a>
            </li>
            <li>
                <a href="/admin/bracket" class="<%= active === 'bracket' ? 'active' : '' %>">
                    <i class="bi bi-diagram-3"></i>ตารางแข่งขัน
                </a>
            </li>
            <li>
                <a href="/admin/settings" class="<%= active === 'settings' ? 'active' : '' %>">
                    <i class="bi bi-gear"></i>ตั้งค่า
                </a>
            </li>
            <li>
                <a href="/">
                    <i class=" bi bi-box-arrow-up-right"></i>ดูหน้าเว็บ
                </a>
            </li>
            <li>
                <a href="#" onclick="logout()">
                    <i class="bi bi-box-arrow-right"></i>ออกจากระบบ
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
        <%- body %>
    </main>

    <script>
        function logout() {
            fetch('/api/admin/logout', { method: 'POST', credentials: 'include' })
                .then(() => window.location.href = '/admin/login');
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>